{%- style -%}
  /* Boxless, premium brand logos — no cards, grayscale that colours on hover */
  #BM--{{ section.id }} .brand-card { background: transparent; border: none; box-shadow: none; min-width: auto; width: auto; height: 84px; padding: 0 2.75rem; display: flex; align-items: center; justify-content: center; }
  #BM--{{ section.id }} .brand-img { max-height: 50px; width: auto; object-fit: contain; filter: grayscale(1); opacity: 0.65; transition: filter 0.2s ease-out, opacity 0.2s ease-out; }
  #BM--{{ section.id }} .brand-card:hover .brand-img { filter: grayscale(0); opacity: 1; }
{%- endstyle -%}
<section class="featured-brands" id="BM--{{ section.id }}">
  <div class="container text-center">
    <p style="color: var(--brand-primary); font-weight:700; letter-spacing:0.1em; text-transform:uppercase; font-size:0.8rem; margin-bottom:0.5rem;">{{ section.settings.eyebrow }}</p>
    <h2 class="section-title">{{ section.settings.heading }}</h2>
    <div class="brand-marquee-container mt-8">
      <div class="brand-marquee-inner">
        {%- comment -%} First Set {%- endcomment -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'logo' -%}
            <div class="brand-card" {{ block.shopify_attributes }}>
              {%- render 'brand-logo', name: block.settings.name, image: block.settings.image, link: '/collections/all', style: 'marquee' -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
        {%- comment -%} Duplicate Set for Seamless Loop {%- endcomment -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'logo' -%}
            <div class="brand-card" aria-hidden="true">
              {%- render 'brand-logo', name: block.settings.name, image: block.settings.image, link: '/collections/all', style: 'marquee' -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Brand Marquee",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Featured Brands" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "We Work With" }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Brand Logo",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Logo" },
        { "type": "text", "id": "name", "label": "Brand name", "default": "Brand" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Brand Marquee",
      "blocks": [
        { "type": "logo", "settings": { "name": "Amazon" } },
        { "type": "logo", "settings": { "name": "Chink" } },
        { "type": "logo", "settings": { "name": "Glint" } },
        { "type": "logo", "settings": { "name": "Ledvance" } },
        { "type": "logo", "settings": { "name": "Vettam" } },
        { "type": "logo", "settings": { "name": "DG Lighting" } },
        { "type": "logo", "settings": { "name": "B.lux" } },
        { "type": "logo", "settings": { "name": "Insight" } },
        { "type": "logo", "settings": { "name": "Zanfi" } }
      ]
    }
  ]
}
{% endschema %}
