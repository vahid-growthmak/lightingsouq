<section class="section {{ section.settings.bg }}">
  <div class="container">
    <h2 class="section-title text-center">{{ section.settings.heading }}</h2>
    <p class="section-sub text-center mb-8">{{ section.settings.subtitle }}</p>
    <div class="brand-strip-grid">
      {%- assign brand_blocks = 0 -%}
      {%- for block in section.blocks -%}{%- if block.type == 'brand' -%}{%- assign brand_blocks = brand_blocks | plus: 1 -%}{%- endif -%}{%- endfor -%}
      {%- if brand_blocks > 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'brand' -%}
            <span {{ block.shopify_attributes }}>{%- render 'brand-logo', name: block.settings.name, image: block.settings.image, link: block.settings.link -%}</span>
          {%- endif -%}
        {%- endfor -%}
      {%- else -%}
        {%- comment -%} No blocks configured — show the store's brand collections so this is never empty {%- endcomment -%}
        {%- assign d_names = 'Ledvance,Philips,Wink,Glint,Osram' | split: ',' -%}
        {%- assign d_links = '/pages/ledvance,/pages/philips,/pages/wink,/pages/glint,/pages/osram' | split: ',' -%}
        {%- for name in d_names -%}
          {%- render 'brand-logo', name: name, link: d_links[forloop.index0] -%}
        {%- endfor -%}
      {%- endif -%}
    </div>
    {%- if section.settings.view_all_label != blank -%}
      <div style="text-align:center;margin-top:1.75rem;">
        <a class="btn-view-more" href="{{ section.settings.view_all_link | default: '/pages/brands' }}">{{ section.settings.view_all_label }} <span class="material-symbols-outlined">arrow_forward</span></a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Brand Strip",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shop by Brand" },
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "From value picks to premium ecosystems — go straight to your brand." },
    { "type": "text", "id": "view_all_label", "label": "View all label", "default": "View All Brands" },
    { "type": "url", "id": "view_all_link", "label": "View all link" },
    {
      "type": "select",
      "id": "bg",
      "label": "Background",
      "options": [
        { "value": "bg-white", "label": "White" },
        { "value": "bg-gray", "label": "Gray" }
      ],
      "default": "bg-gray"
    }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "Brand",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Logo" },
        { "type": "text", "id": "name", "label": "Brand name", "default": "Brand" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Brand Strip",
      "blocks": [
        { "type": "brand", "settings": { "name": "Ledvance" } },
        { "type": "brand", "settings": { "name": "Glint" } },
        { "type": "brand", "settings": { "name": "Vettam" } },
        { "type": "brand", "settings": { "name": "DG Lighting" } },
        { "type": "brand", "settings": { "name": "B.lux" } },
        { "type": "brand", "settings": { "name": "Insight" } },
        { "type": "brand", "settings": { "name": "Zanfi" } },
        { "type": "brand", "settings": { "name": "Chink" } },
        { "type": "brand", "settings": { "name": "Amazon" } }
      ]
    }
  ]
}
{% endschema %}
