<section class="bulk-band" id="bulk">
  <div class="container">
    <div class="bulk-band-inner">
      <div>
        <p class="bulk-band-title">{{ section.settings.title }}</p>
        <p class="bulk-band-sub">{{ section.settings.subtitle }}</p>
      </div>
      <a href="{{ section.settings.button_link | default: routes.root_url }}" class="btn-outline rbo-open">{{ section.settings.button_label }}</a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Bulk Band",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "title", "label": "Title", "default": "Buying in volume for a project, cafe or villa?" },
    { "type": "textarea", "id": "subtitle", "label": "Subtitle", "default": "Add items to a quote and our team sends volume pricing — same-day Doha & GCC delivery." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Request a Bulk Quote" },
    { "type": "url", "id": "button_link", "label": "Button link" }
  ],
  "presets": [
    { "name": "Bulk Band" }
  ]
}
{% endschema %}
