<section class="section {{ section.settings.bg }}">
  <div class="container">
    <h2 class="section-title text-center">{{ section.settings.heading }}</h2>
    {%- if section.settings.intro != blank -%}<p class="section-sub text-center">{{ section.settings.intro }}</p>{%- endif -%}
    <div class="grid-4 mt-8">
      {%- for block in section.blocks -%}
        {%- if block.type == 'category' -%}
          {%- liquid
            assign c = collections[block.settings.collection]
            assign is_dynamic = false
            if block.settings.collection != blank and c != empty
              assign is_dynamic = true
            endif
          -%}
          {%- assign cat_url = block.settings.link -%}
          {%- if is_dynamic -%}{%- assign cat_url = c.url -%}{%- endif -%}
          <a href="{{ cat_url | default: '/collections/all' }}" class="category-card" {{ block.shopify_attributes }}>
            <div class="cat-img-wrap">
              {%- if is_dynamic and c.image != blank -%}
                <img src="{{ c.image | image_url: width: 800 }}" alt="{{ c.title | escape }}" width="800" height="800" loading="lazy" style="width:100%;height:100%;object-fit:cover;">
              {%- elsif is_dynamic and c.products.first.featured_image != blank -%}
                <img src="{{ c.products.first.featured_image | image_url: width: 800 }}" alt="{{ c.title | escape }}" width="800" height="800" loading="lazy" style="width:100%;height:100%;object-fit:cover;">
              {%- elsif block.settings.image != blank -%}
                <img src="{{ block.settings.image | image_url: width: 800 }}" alt="{{ block.settings.title | escape }}" width="800" height="800" loading="lazy" style="width:100%;height:100%;object-fit:cover;">
              {%- else -%}
                <img src="{{ block.settings.fallback | default: 'prod-bulb.png' | asset_url }}" alt="{{ block.settings.title | escape }}" width="800" height="800" loading="lazy" style="width:100%;height:100%;object-fit:cover;">
              {%- endif -%}
            </div>
            <div class="cat-body">
              <h3 class="cat-title">{% if is_dynamic %}{{ c.title }}{% else %}{{ block.settings.title }}{% endif %}</h3>
              <p class="cat-count">{% if is_dynamic %}{{ c.products_count }} Products{% else %}{{ block.settings.count }}{% endif %}</p>
              <span class="cat-link">{{ block.settings.link_label | default: 'Shop Now →' }}</span>
            </div>
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Shop by Category",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shop by Category" },
    { "type": "text", "id": "intro", "label": "Intro line (optional)" },
    {
      "type": "select",
      "id": "bg",
      "label": "Background",
      "options": [
        { "value": "bg-white", "label": "White" },
        { "value": "bg-gray", "label": "Gray" }
      ],
      "default": "bg-white"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        { "type": "paragraph", "content": "Pick a collection to auto-fill title, image, product count and link. Leave empty to use the manual fields below." },
        { "type": "collection", "id": "collection", "label": "Collection" },
        { "type": "header", "content": "Manual (fallback)" },
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "fallback", "label": "Fallback asset filename", "default": "prod-bulb.png" },
        { "type": "text", "id": "title", "label": "Title", "default": "Category" },
        { "type": "text", "id": "count", "label": "Product count", "default": "120+ Products" },
        { "type": "url", "id": "link", "label": "Link", "default": "/collections/all" },
        { "type": "text", "id": "link_label", "label": "Link label", "default": "Shop Now →" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop by Category",
      "blocks": [
        { "type": "category", "settings": { "fallback": "prod-bulb.png", "title": "Smart Bulbs", "count": "120+ Products", "link": "/collections/all" } },
        { "type": "category", "settings": { "fallback": "prod-tube.png", "title": "LED Tubes", "count": "85+ Products", "link": "/collections/all" } },
        { "type": "category", "settings": { "fallback": "space-smart.png", "title": "RGB Strips", "count": "45+ Products", "link": "/collections/all" } },
        { "type": "category", "settings": { "fallback": "space-office.png", "title": "Ceiling Lights", "count": "95+ Products", "link": "/collections/all" } },
        { "type": "category", "settings": { "fallback": "prod-pendant.png", "title": "Pendant Lamps", "count": "70+ Products", "link": "/collections/all" } },
        { "type": "category", "settings": { "fallback": "prod-living.png", "title": "Floor Lamps", "count": "55+ Products", "link": "/collections/all" } },
        { "type": "category", "settings": { "fallback": "prod-solar.png", "title": "Solar Lights", "count": "60+ Products", "link": "/collections/all" } },
        { "type": "category", "settings": { "fallback": "space-outdoor.png", "title": "Outdoor Lights", "count": "80+ Products", "link": "/collections/all" } }
      ]
    }
  ]
}
{% endschema %}
