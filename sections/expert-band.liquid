<section class="pdp-section" style="border-bottom:1px solid var(--gray-200);">
  <div class="expert-band">
    <div>
      <h3>{{ section.settings.heading }}</h3>
      <p>{{ section.settings.text }}</p>
    </div>
    {%- liquid
      assign eb_href = section.settings.button_link
      if eb_href == blank and settings.whatsapp_number != blank
        assign eb_num = settings.whatsapp_number | remove: ' ' | remove: '-' | remove: '+' | remove: '(' | remove: ')'
        assign eb_msg = 'Hi! I need help checking if a product fits my setup.' | url_encode
        assign eb_href = 'https://wa.me/' | append: eb_num | append: '?text=' | append: eb_msg
      endif
    -%}
    <a href="{{ eb_href | default: '/pages/contact' }}" class="btn-whatsapp"{% if eb_href contains 'wa.me' %} target="_blank" rel="noopener"{% endif %}><span class="material-symbols-outlined">chat</span> {{ section.settings.button_label }}</a>
  </div>
</section>

{% schema %}
{
  "name": "PDP Expert Band",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Not sure it fits? Ask an expert."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Message our Doha showroom team for spec & compatibility help — real people, fast replies."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Chat on WhatsApp"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "PDP Expert Band"
    }
  ]
}
{% endschema %}
