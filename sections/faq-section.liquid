{%- liquid
  assign bg = section.settings.bg
-%}
<section class="section {{ bg }}" id="FAQS--{{ section.id }}">
  <div class="container">
    {%- if section.settings.heading != blank -%}
      <h2 class="section-title text-center">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.subtitle != blank -%}
      <p class="section-sub text-center mb-8">{{ section.settings.subtitle }}</p>
    {%- endif -%}
    <div class="faq-wrap">
      {%- for block in section.blocks -%}
        {%- if block.type == 'faq' -%}
        <div class="collapsible-row{% if forloop.first %} active{% endif %}" {{ block.shopify_attributes }}>
          <h3 class="collapsible-trigger-h"><button class="collapsible-trigger" type="button" data-accordion>{{ block.settings.question }} <span class="material-symbols-outlined">expand_more</span></button></h3>
          <div class="collapsible-content">{{ block.settings.answer }}</div>
        </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
    {%- if section.settings.footer_label != blank -%}
      <p class="text-center mt-8"><a class="btn-view-more" href="{{ section.settings.footer_link | default: '/pages/faqs' }}">{{ section.settings.footer_label }} <span class="material-symbols-outlined">arrow_forward</span></a></p>
    {%- endif -%}
  </div>
</section>

{%- comment -%} FAQPage JSON-LD — answers pulled from the same blocks so schema and page never drift {%- endcomment -%}
{%- capture faq_ld -%}
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {%- assign fq = 0 -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'faq' and block.settings.question != blank -%}
        {%- if fq > 0 -%},{%- endif -%}
        {%- assign fq = fq | plus: 1 -%}
        {
          "@type": "Question",
          "name": {{ block.settings.question | strip_html | json }},
          "acceptedAnswer": { "@type": "Answer", "text": {{ block.settings.answer | strip_html | strip | json }} }
        }
      {%- endif -%}
    {%- endfor -%}
  ]
}
{%- endcapture -%}
{%- if section.settings.emit_schema -%}<script type="application/ld+json">{{ faq_ld }}</script>{%- endif -%}

<script>
  (function () {
    var root = document.getElementById('FAQS--{{ section.id }}');
    if (!root) return;
    root.addEventListener('click', function (e) {
      var trigger = e.target.closest('[data-accordion]');
      if (!trigger || !root.contains(trigger)) return;
      var row = trigger.closest('.collapsible-row');
      if (row) row.classList.toggle('active');
    });
  })();
</script>

{% schema %}
{
  "name": "FAQ",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Frequently Asked Questions" },
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Answers to the questions we hear most." },
    { "type": "text", "id": "footer_label", "label": "Footer link label (optional)" },
    { "type": "url", "id": "footer_link", "label": "Footer link" },
    { "type": "checkbox", "id": "emit_schema", "label": "Output FAQ schema (JSON-LD)", "default": true },
    {
      "type": "select",
      "id": "bg",
      "label": "Background",
      "options": [
        { "value": "bg-white", "label": "White" },
        { "value": "bg-gray", "label": "Gray" }
      ],
      "default": "bg-white"
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ Item",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "Add your question here" },
        { "type": "richtext", "id": "answer", "label": "Answer", "default": "<p>Add your answer here.</p>" }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ",
      "blocks": [
        {
          "type": "faq",
          "settings": {
            "question": "Are your products genuine and covered by warranty?",
            "answer": "<p>Yes. Every product is 100% genuine with a <strong>local warranty</strong> handled by our Doha team — never a grey-market import.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "How fast is delivery in Qatar?",
            "answer": "<p>Order before 4 PM for <strong>same-day delivery in Doha</strong>. Elsewhere in Qatar it is 1–2 days, and we also ship across the GCC.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "Will smart lights work with Alexa, Google or Siri?",
            "answer": "<p>Most of our smart range works with <strong>Alexa, Google Home and Apple Home</strong> via apps like Tuya, Smart Life, Mi Home and Hue. See our setup guides for step-by-step help.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "What is your return policy?",
            "answer": "<p>You can return within <strong>7 days</strong> of delivery in the original, unused packaging. See our returns page for the full policy.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
