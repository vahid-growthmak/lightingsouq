<div class="featured-banner"{% if section.settings.background_image != blank %} style="background-image: linear-gradient(rgba(0,0,0,.45), rgba(0,0,0,.45)), url({{ section.settings.background_image | image_url: width: 1600 }});"{% endif %}>
  <div class="container text-center">
    <h2 class="featured-title">{{ section.settings.title }}</h2>
    <p class="featured-sub">{{ section.settings.subtitle }}</p>
    <a href="{{ section.settings.button_link }}" class="btn-secondary">{{ section.settings.button_label }}</a>
  </div>
</div>

{% schema %}
{
  "name": "Featured Banner",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "title", "label": "Title", "default": "Upgrade Every Corner with Better Lighting" },
    { "type": "textarea", "id": "subtitle", "label": "Subtitle", "default": "From daily-use bulbs to decorative lamps and outdoor solar lights, find everything in one store." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Shop All Products" },
    { "type": "url", "id": "button_link", "label": "Button link", "default": "/collections/all" },
    { "type": "image_picker", "id": "background_image", "label": "Background image (optional)" }
  ],
  "presets": [
    { "name": "Featured Banner" }
  ]
}
{% endschema %}
