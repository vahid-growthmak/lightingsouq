  ],
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        { "type": "social", "settings": { "network": "facebook", "url": "#", "aria": "Facebook" } },
        { "type": "social", "settings": { "network": "instagram", "url": "#", "aria": "Instagram" } },
        {
          "type": "link_column",
          "settings": {
            "heading": "Shop Categories",
            "label_1": "Smart Bulbs", "url_1": "/collections/all",
            "label_2": "LED Tubes", "url_2": "/collections/all",
            "label_3": "RGB Strips", "url_3": "/collections/all",
            "label_4": "Ceiling Lights", "url_4": "/collections/all",
            "label_5": "Pendant Lamps", "url_5": "/collections/all",
            "label_6": "Solar Lights", "url_6": "/collections/all",
            "label_7": "Outdoor Lights", "url_7": "/collections/all"
