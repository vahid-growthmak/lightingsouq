        { "type": "text", "id": "aria", "label": "Accessible name", "default": "Social" }
      ]
    },
    {
      "type": "link_column",
      "name": "Link column",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Column" },
        { "type": "text", "id": "label_1", "label": "Label 1" },
        { "type": "url", "id": "url_1", "label": "URL 1" },
        { "type": "text", "id": "label_2", "label": "Label 2" },
        { "type": "url", "id": "url_2", "label": "URL 2" },
        { "type": "text", "id": "label_3", "label": "Label 3" },
        { "type": "url", "id": "url_3", "label": "URL 3" },
        { "type": "text", "id": "label_4", "label": "Label 4" },
        { "type": "url", "id": "url_4", "label": "URL 4" },
        { "type": "text", "id": "label_5", "label": "Label 5" },
        { "type": "url", "id": "url_5", "label": "URL 5" },
        { "type": "text", "id": "label_6", "label": "Label 6" },
        { "type": "url", "id": "url_6", "label": "URL 6" },
        { "type": "text", "id": "label_7", "label": "Label 7" },
        { "type": "url", "id": "url_7", "label": "URL 7" }
      ]
    },
    {
      "type": "payment",
      "name": "Payment badge",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "VISA" }
      ]
