<!-- Footer -->
<footer class="footer">
  <div class="container">
    <div class="footer-grid">

      <div class="footer-brand">
        <div class="footer-logo">
          {%- if settings.logo_image != blank -%}
            <a href="{{ routes.root_url }}" class="footer-logo-chip" aria-label="{{ shop.name | escape }}"><img src="{{ settings.logo_image | image_url: width: 520 }}" alt="{{ shop.name | escape }}" loading="lazy"></a>
          {%- else -%}
            {{ section.settings.logo_text }}<span class="logo-accent">{{ section.settings.logo_accent }}</span>
          {%- endif -%}
        </div>
        <p class="footer-desc">{{ section.settings.description }}</p>
        <div class="social-links">
          {%- for block in section.blocks -%}
            {%- if block.type == 'social' -%}
              <a href="{{ block.settings.url | default: '#' }}" class="social-btn" aria-label="{{ block.settings.aria }}" target="_blank" rel="noopener" {{ block.shopify_attributes }}>
                {%- case block.settings.network -%}
                  {%- when 'facebook' -%}
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 24 24"><path d="M22 12a10 10 0 1 0-11.56 9.88v-6.99H7.9V12h2.54V9.8c0-2.51 1.5-3.9 3.78-3.9 1.1 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56V12h2.78l-.44 2.89h-2.34v6.99A10 10 0 0 0 22 12z"/></svg>
                  {%- when 'instagram' -%}
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
                  {%- when 'youtube' -%}
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 24 24"><path d="M23 12s0-3.2-.4-4.7a2.5 2.5 0 0 0-1.77-1.77C19.34 5.13 12 5.13 12 5.13s-7.34 0-8.83.4A2.5 2.5 0 0 0 1.4 7.3C1 8.8 1 12 1 12s0 3.2.4 4.7a2.5 2.5 0 0 0 1.77 1.77c1.49.4 8.83.4 8.83.4s7.34 0 8.83-.4a2.5 2.5 0 0 0 1.77-1.77C23 15.2 23 12 23 12zM9.75 15.02V8.98L15.5 12l-5.75 3.02z"/></svg>
                  {%- when 'linkedin' -%}
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 24 24"><path d="M20.45 20.45h-3.56v-5.57c0-1.33-.03-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.07 2.07 0 1 1 0-4.14 2.07 2.07 0 0 1 0 4.14zM7.12 20.45H3.55V9h3.57v11.45zM22.22 0H1.77C.8 0 0 .77 0 1.73v20.54C0 23.22.8 24 1.77 24h20.45c.98 0 1.78-.78 1.78-1.73V1.73C24 .77 23.2 0 22.22 0z"/></svg>
                  {%- when 'x', 'twitter' -%}
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M18.24 2H21.5l-7.13 8.15L22.75 22h-6.56l-5.14-6.72L5.17 22H1.9l7.62-8.71L1.25 2h6.72l4.65 6.14L18.24 2zm-1.15 18h1.81L7.01 3.9H5.06L17.09 20z"/></svg>
                  {%- when 'tiktok' -%}
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 24 24"><path d="M16.6 5.82a4.28 4.28 0 0 1-1.06-2.82h-3.1v12.4a2.6 2.6 0 1 1-2.6-2.6c.27 0 .53.04.78.12v-3.2a5.8 5.8 0 1 0 4.92 5.73V9.02a7.3 7.3 0 0 0 4.26 1.36V7.28a4.28 4.28 0 0 1-3.2-1.46z"/></svg>
                  {%- else -%}
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M8 12h8M12 8v8"/></svg>
                {%- endcase -%}
              </a>
            {%- endif -%}
          {%- endfor -%}
        </div>
        {%- if section.settings.reviews_show -%}
          <div class="footer-reviews">
            {%- assign fr_rating = settings.google_rating | default: section.settings.reviews_rating -%}
            {%- assign fr_count = settings.google_count | default: section.settings.reviews_count -%}
            {%- assign fr_link = settings.google_reviews_url | default: section.settings.reviews_link -%}
            {%- render 'google-reviews', rating: fr_rating, count: fr_count, link: fr_link, variant: 'onblue' -%}
          </div>
        {%- endif -%}
      </div>

      {%- for block in section.blocks -%}
        {%- if block.type == 'link_column' -%}
          <div class="footer-col footer-col--links" {{ block.shopify_attributes }}>
            <button class="footer-heading" type="button" data-footer-acc aria-expanded="false">{{ block.settings.heading }}</button>
            <ul class="footer-list">
              {%- for i in (1..7) -%}
                {%- assign label_key = 'label_' | append: i -%}
                {%- assign url_key = 'url_' | append: i -%}
                {%- assign label = block.settings[label_key] -%}
                {%- assign url = block.settings[url_key] -%}
                {%- if label != blank -%}
                  <li><a href="{{ url | default: '#' }}">{{ label }}</a></li>
                {%- endif -%}
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}
      {%- endfor -%}

      <div class="footer-col">
        <h3 class="footer-heading">{{ section.settings.newsletter_heading }}</h3>
        <p class="footer-desc">{{ section.settings.newsletter_desc }}</p>
        <form method="post" action="/contact#newsletter" accept-charset="UTF-8" class="newsletter-form">
          <input type="hidden" name="form_type" value="customer">
          <input type="hidden" name="contact[tags]" value="newsletter">
          <input type="email" name="contact[email]" class="newsletter-input" placeholder="{{ section.settings.newsletter_placeholder }}" required>
          <button class="btn-subscribe" type="submit">{{ section.settings.newsletter_button }}</button>
        </form>
        <div class="contact-info">
          {%- assign tel_href = section.settings.phone | remove: ' ' | remove: '-' | remove: '(' | remove: ')' -%}
          <a class="contact-item" href="tel:{{ tel_href }}"><span class="material-symbols-outlined" style="font-size:1.1rem;">call</span><span>{{ section.settings.phone }}</span></a>
          <a class="contact-item" href="mailto:{{ section.settings.email }}"><span class="material-symbols-outlined" style="font-size:1.1rem;">mail</span><span>{{ section.settings.email }}</span></a>
          <div class="contact-item"><span class="material-symbols-outlined" style="font-size:1.1rem;">schedule</span><span>{{ section.settings.hours }}</span></div>
        </div>
      </div>

    </div>

    <div class="footer-legal">
      <div class="footer-legal-links">
        {%- if shop.privacy_policy != blank -%}<a href="{{ shop.privacy_policy.url }}">Privacy Policy</a>{%- endif -%}
        {%- if shop.terms_of_service != blank -%}<a href="{{ shop.terms_of_service.url }}">Terms of Service</a>{%- endif -%}
        {%- if shop.refund_policy != blank -%}<a href="{{ shop.refund_policy.url }}">Refund Policy</a>{%- endif -%}
        {%- if shop.shipping_policy != blank -%}<a href="{{ shop.shipping_policy.url }}">Shipping Policy</a>{%- endif -%}
        {%- if section.settings.warranty_label != blank -%}<a href="{{ section.settings.warranty_link | default: '/pages/warranty' }}">{{ section.settings.warranty_label }}</a>{%- endif -%}
        {%- if section.settings.reviews_label != blank -%}<a href="{{ section.settings.reviews_page_link | default: '/pages/reviews' }}">{{ section.settings.reviews_label }}</a>{%- endif -%}
        {%- if section.settings.allcollections_label != blank -%}<a href="{{ section.settings.allcollections_link | default: '/collections' }}">{{ section.settings.allcollections_label }}</a>{%- endif -%}
        {%- if section.settings.blog_label != blank -%}<a href="{{ section.settings.blog_link | default: '/blogs/news' }}">{{ section.settings.blog_label }}</a>{%- endif -%}
      </div>
      {%- if settings.theqa_image != blank -%}
        <div class="footer-theqa">
          {%- if settings.theqa_link != blank -%}<a href="{{ settings.theqa_link }}" target="_blank" rel="noopener" aria-label="{{ settings.theqa_alt | default: 'Theqa Certified Store' }}">{%- endif -%}
            <img src="{{ settings.theqa_image | image_url: width: 480 }}" alt="{{ settings.theqa_alt | default: 'Theqa Certified Store' }}" width="240" loading="lazy">
          {%- if settings.theqa_link != blank -%}</a>{%- endif -%}
        </div>
      {%- endif -%}
    </div>

    <div class="footer-bottom">
      <div class="footer-copy">{{ section.settings.copyright }}</div>
      <div class="payment-methods">
        <span>{{ section.settings.accept_label }}</span>
        {%- for block in section.blocks -%}
          {%- if block.type == 'payment' -%}
            <span class="pay-ico" {{ block.shopify_attributes }}>{%- render 'payment-icon', label: block.settings.label -%}</span>
          {%- endif -%}
        {%- endfor -%}
      </div>
      </div>
    </div>
  </div>
</footer>

<script>
  (function () {
    /* Mobile/tablet footer accordions (below 1024px only) */
    document.querySelectorAll('[data-footer-acc]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        if (window.matchMedia('(min-width: 1024px)').matches) return;
        var col = btn.closest('.footer-col--links');
        if (!col) return;
        var open = col.classList.toggle('open');
        btn.setAttribute('aria-expanded', open ? 'true' : 'false');
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Footer",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Brand" },
    { "type": "text", "id": "logo_text", "label": "Logo text", "default": "LIGHTING" },
    { "type": "text", "id": "logo_accent", "label": "Logo accent", "default": "SOUQ" },
    { "type": "textarea", "id": "description", "label": "Description", "default": "Lighting Souq is Qatar's online lighting supermarket for bulbs, lamps, tubes, solar lights, smart switches and more." },

    { "type": "header", "content": "Newsletter" },
    { "type": "text", "id": "newsletter_heading", "label": "Heading", "default": "Newsletter" },
    { "type": "text", "id": "newsletter_desc", "label": "Description", "default": "Get offers and new product updates" },
    { "type": "text", "id": "newsletter_placeholder", "label": "Input placeholder", "default": "Your email" },
    { "type": "text", "id": "newsletter_button", "label": "Button label", "default": "Subscribe" },

    { "type": "header", "content": "Contact" },
    { "type": "text", "id": "phone", "label": "Phone", "default": "+974 1234 5678" },
    { "type": "text", "id": "email", "label": "Email", "default": "info@lightingsouq.qa" },
    { "type": "text", "id": "hours", "label": "Hours", "default": "Sat-Thu: 9AM-9PM" },

    { "type": "header", "content": "Google reviews" },
    { "type": "checkbox", "id": "reviews_show", "label": "Show Google reviews badge", "default": true },
    { "type": "text", "id": "reviews_rating", "label": "Rating", "default": "4.9" },
    { "type": "text", "id": "reviews_count", "label": "Review count", "default": "84" },
    { "type": "url", "id": "reviews_link", "label": "Google reviews link" },

    { "type": "header", "content": "Bottom bar" },
    { "type": "text", "id": "copyright", "label": "Copyright", "default": "© 2026 Lighting Souq. All rights reserved. | Theqa Certified Store" },
    { "type": "text", "id": "accept_label", "label": "Accept label", "default": "We Accept:" },

    { "type": "header", "content": "Legal row links" },
    { "type": "text", "id": "warranty_label", "label": "Warranty label" },
    { "type": "url", "id": "warranty_link", "label": "Warranty link" },
    { "type": "text", "id": "reviews_label", "label": "Reviews label", "default": "Reviews" },
    { "type": "url", "id": "reviews_page_link", "label": "Reviews link" },
    { "type": "text", "id": "allcollections_label", "label": "All Collections label", "default": "All Collections" },
    { "type": "url", "id": "allcollections_link", "label": "All Collections link" },
    { "type": "text", "id": "blog_label", "label": "Blog label", "default": "Blog" },
    { "type": "url", "id": "blog_link", "label": "Blog link" }
  ],
  "blocks": [
    {
      "type": "social",
      "name": "Social link",
      "settings": [
        {
          "type": "select",
          "id": "network",
          "label": "Network",
          "options": [
            { "value": "facebook", "label": "Facebook" },
            { "value": "instagram", "label": "Instagram" },
            { "value": "x", "label": "X" },
            { "value": "tiktok", "label": "TikTok" },
            { "value": "youtube", "label": "YouTube" },
            { "value": "linkedin", "label": "LinkedIn" },
            { "value": "whatsapp", "label": "WhatsApp" }
