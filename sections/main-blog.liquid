{%- comment -%}
  Main Blog — featured article + topic chips + paginated grid of article cards.
{%- endcomment -%}
{%- assign featured = blog.articles.first -%}
<section class="section bg-white" id="Sec--{{ section.id }}" aria-labelledby="blog-heading-{{ section.id }}">
  <div class="container">
    <div class="lsq-blog-head">
      <h1 class="section-title" id="blog-heading-{{ section.id }}">{{ section.settings.heading | default: blog.title }}</h1>
      {%- if section.settings.intro != blank -%}
        <p class="section-sub">{{ section.settings.intro }}</p>
      {%- endif -%}
    </div>

    {%- comment -%} Featured article {%- endcomment -%}
    {%- if featured -%}
      <article class="lsq-featured">
        <a class="lsq-featured-media" href="{{ featured.url }}" aria-label="{{ featured.title | escape }}">
          {%- if featured.image -%}
            <img
              src="{{ featured.image | image_url: width: 1200 }}"
              alt="{{ featured.image.alt | default: featured.title | escape }}"
              width="1200" height="675" loading="eager">
          {%- else -%}
            <span class="lsq-noimg" aria-hidden="true"><span class="material-symbols-outlined">image</span></span>
          {%- endif -%}
        </a>
        <div class="lsq-featured-body">
          {%- if featured.tags.size > 0 -%}
            <span class="lsq-chip lsq-chip-solid">{{ featured.tags.first }}</span>
          {%- endif -%}
          <h2 class="lsq-featured-title"><a href="{{ featured.url }}">{{ featured.title }}</a></h2>
          {%- if featured.excerpt_or_content != blank -%}
            <p class="lsq-featured-excerpt">{{ featured.excerpt_or_content | strip_html | truncatewords: 34 }}</p>
          {%- endif -%}
          <p class="lsq-meta">{{ featured.published_at | date: "%b %d, %Y" }}</p>
          <a class="btn-primary lsq-featured-cta" href="{{ featured.url }}">{{ section.settings.read_more }}</a>
        </div>
      </article>
    {%- endif -%}

    {%- comment -%} Topic chips {%- endcomment -%}
    {%- if blog.all_tags.size > 0 -%}
      <nav class="lsq-topics" aria-label="Topics">
        <a class="lsq-chip{% unless current_tags %} lsq-chip-active{% endunless %}" href="{{ blog.url }}">{{ section.settings.all_label }}</a>
        {%- for tag in blog.all_tags -%}
          <a class="lsq-chip{% if current_tags contains tag %} lsq-chip-active{% endif %}" href="{{ blog.url }}?tag={{ tag | url_encode }}">{{ tag }}</a>
        {%- endfor -%}
      </nav>
    {%- endif -%}

    {%- comment -%} Article grid (skip the featured one) {%- endcomment -%}
    {%- paginate blog.articles by 9 -%}
      <div class="grid-3 lsq-blog-grid">
        {%- for article in blog.articles -%}
          {%- unless article.id == featured.id and paginate.current_page == 1 and current_tags == empty -%}
            <article class="lsq-card">
              <a class="lsq-card-media" href="{{ article.url }}" aria-label="{{ article.title | escape }}">
                {%- if article.image -%}
                  <img
                    src="{{ article.image | image_url: width: 640 }}"
                    alt="{{ article.image.alt | default: article.title | escape }}"
                    width="640" height="400" loading="lazy">
                {%- else -%}
                  <span class="lsq-noimg" aria-hidden="true"><span class="material-symbols-outlined">image</span></span>
                {%- endif -%}
              </a>
              <div class="lsq-card-body">
                {%- if article.tags.size > 0 -%}
                  <span class="lsq-chip">{{ article.tags.first }}</span>
                {%- endif -%}
                <h3 class="lsq-card-title"><a href="{{ article.url }}">{{ article.title }}</a></h3>
                {%- if article.excerpt_or_content != blank -%}
                  <p class="lsq-card-excerpt">{{ article.excerpt_or_content | strip_html | truncatewords: 20 }}</p>
                {%- endif -%}
                <div class="lsq-card-foot">
                  <span class="lsq-meta">{{ article.published_at | date: "%b %d, %Y" }}</span>
                  <a class="lsq-card-link" href="{{ article.url }}">{{ section.settings.read_more }}</a>
                </div>
              </div>
            </article>
          {%- endunless -%}
        {%- else -%}
          <p>{{ section.settings.empty_text }}</p>
        {%- endfor -%}
      </div>

      {%- if paginate.pages > 1 -%}
        <nav class="pagination lsq-pagination" role="navigation" aria-label="Pagination">
          {%- if paginate.previous -%}
            <a class="page-btn" href="{{ paginate.previous.url }}" aria-label="Previous page">
              <span class="material-symbols-outlined">chevron_left</span>
            </a>
          {%- endif -%}
          {%- for part in paginate.parts -%}
            {%- if part.is_link -%}
              <a class="page-btn" href="{{ part.url }}">{{ part.title }}</a>
            {%- else -%}
              <span class="page-btn page-btn-active" aria-current="page">{{ part.title }}</span>
            {%- endif -%}
          {%- endfor -%}
          {%- if paginate.next -%}
            <a class="page-btn" href="{{ paginate.next.url }}" aria-label="Next page">
              <span class="material-symbols-outlined">chevron_right</span>
            </a>
          {%- endif -%}
        </nav>
      {%- endif -%}
    {%- endpaginate -%}
  </div>
</section>

{% style %}
  #Sec--{{ section.id }} .lsq-blog-head { margin-bottom: 1.5rem; }
  #Sec--{{ section.id }} .lsq-featured {
    display: grid;
    gap: 1.25rem;
    background: #fff;
    border: 1px solid var(--gray-200, #E5E7EB);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: 0 6px 24px rgba(17,24,39,0.08);
    margin-bottom: 2rem;
  }
  #Sec--{{ section.id }} .lsq-featured-media,
  #Sec--{{ section.id }} .lsq-card-media { display: block; overflow: hidden; background: #f3f4f6; }
  #Sec--{{ section.id }} .lsq-featured-media img,
  #Sec--{{ section.id }} .lsq-card-media img { width: 100%; height: 100%; object-fit: cover; display: block; }
  #Sec--{{ section.id }} .lsq-featured-body { padding: 0 1.5rem 1.75rem; }
  #Sec--{{ section.id }} .lsq-featured-title { font-size: clamp(1.35rem, 4vw, 2rem); font-weight: 700; line-height: 1.2; margin: 0.75rem 0; }
  #Sec--{{ section.id }} .lsq-featured-title a { color: inherit; text-decoration: none; }
  #Sec--{{ section.id }} .lsq-featured-title a:hover { color: var(--brand-primary); }
  #Sec--{{ section.id }} .lsq-featured-excerpt { color: var(--gray-500); line-height: 1.7; margin-bottom: 0.75rem; }
  #Sec--{{ section.id }} .lsq-featured-cta { margin-top: 0.75rem; }
  @media (min-width: 768px) {
    #Sec--{{ section.id }} .lsq-featured { grid-template-columns: 1.15fr 1fr; align-items: center; }
    #Sec--{{ section.id }} .lsq-featured-body { padding: 2rem 2rem 2rem 0.5rem; }
  }

  #Sec--{{ section.id }} .lsq-topics { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1.75rem; }
  #Sec--{{ section.id }} .lsq-chip {
    display: inline-block;
    padding: 0.3125rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.8125rem;
    font-weight: 600;
    text-decoration: none;
    background: #f3f4f6;
    color: var(--gray-500);
    border: 1px solid transparent;
  }
  #Sec--{{ section.id }} a.lsq-chip:hover { border-color: var(--brand-primary); color: var(--brand-primary); }
  #Sec--{{ section.id }} .lsq-chip-active { background: var(--brand-primary); color: #fff; }
  #Sec--{{ section.id }} .lsq-chip-solid { background: var(--brand-secondary); color: #fff; margin-bottom: 0.25rem; }

  #Sec--{{ section.id }} .lsq-card {
    display: flex;
    flex-direction: column;
    background: #fff;
    border: 1px solid var(--gray-200, #E5E7EB);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: 0 2px 10px rgba(17,24,39,0.06);
    transition: box-shadow 150ms ease-out, transform 150ms ease-out;
  }
  #Sec--{{ section.id }} .lsq-card:hover { box-shadow: 0 10px 28px rgba(17,24,39,0.12); transform: translateY(-2px); }
  #Sec--{{ section.id }} .lsq-card-media { aspect-ratio: 16 / 10; }
  #Sec--{{ section.id }} .lsq-card-body { padding: 1rem 1.125rem 1.25rem; display: flex; flex-direction: column; gap: 0.5rem; flex: 1; }
  #Sec--{{ section.id }} .lsq-card-title { font-size: 1.125rem; font-weight: 700; line-height: 1.3; }
  #Sec--{{ section.id }} .lsq-card-title a { color: inherit; text-decoration: none; }
  #Sec--{{ section.id }} .lsq-card-title a:hover { color: var(--brand-primary); }
  #Sec--{{ section.id }} .lsq-card-excerpt { color: var(--gray-500); font-size: 0.9375rem; line-height: 1.6; }
  #Sec--{{ section.id }} .lsq-card-foot { display: flex; align-items: center; justify-content: space-between; margin-top: auto; padding-top: 0.5rem; }
  #Sec--{{ section.id }} .lsq-card-link { color: var(--brand-primary); font-weight: 600; text-decoration: none; font-size: 0.9375rem; }
  #Sec--{{ section.id }} .lsq-card-link:hover { text-decoration: underline; }
  #Sec--{{ section.id }} .lsq-meta { color: var(--gray-500); font-size: 0.8125rem; }

  #Sec--{{ section.id }} .lsq-noimg {
    display: flex; align-items: center; justify-content: center;
    width: 100%; aspect-ratio: 16 / 10; background: #f3f4f6; color: #9ca3af;
  }
  #Sec--{{ section.id }} .lsq-noimg .material-symbols-outlined { font-size: 2.5rem; }

  #Sec--{{ section.id }} .lsq-pagination { margin-top: 2rem; }
  #Sec--{{ section.id }} .lsq-pagination .page-btn-active { background: var(--brand-primary); color: #fff; border-color: var(--brand-primary); }
{% endstyle %}

{% schema %}
{
  "name": "Blog Posts",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Learn" },
    { "type": "text", "id": "intro", "label": "Intro text", "default": "Guides, tips and inspiration to help you light your space." },
    { "type": "text", "id": "all_label", "label": "All topics label", "default": "All" },
    { "type": "text", "id": "read_more", "label": "Read more label", "default": "Read more" },
    { "type": "text", "id": "empty_text", "label": "Empty state text", "default": "No articles yet. Check back soon." }
  ],
  "presets": [
    { "name": "Blog Posts" }
  ]
}
{% endschema %}
