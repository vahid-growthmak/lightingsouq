{%- comment -%}
  Full shopping cart — OS 2.0. Line items with qty + remove, order summary,
  checkout button. Empty-cart state. Qty change auto-submits the form.
{%- endcomment -%}
{%- liquid
  assign s = section.settings
-%}
<section class="section bg-white" id="Sec--{{ section.id }}" aria-labelledby="cart-heading">
  <div class="container">
    <div class="section-header">
      <div>
        <h1 class="section-title" id="cart-heading">{{ s.heading }}</h1>
      </div>
    </div>

    {%- if cart.item_count > 0 -%}
      <form action="{{ routes.cart_url }}" method="post" id="lsq-cart-form" class="lsq-cart">
        <div class="lsq-cart-items">
          {%- for item in cart.items -%}
            <div class="lsq-cart-item">
              <a href="{{ item.url }}" class="lsq-cart-thumb">
                {%- if item.image != blank -%}
                  <img src="{{ item.image | image_url: width: 200 }}" alt="{{ item.title | escape }}" width="100" height="100" loading="lazy">
                {%- endif -%}
              </a>
              <div class="lsq-cart-info">
                <a href="{{ item.url }}" class="lsq-cart-title">{{ item.product.title }}</a>
                {%- unless item.variant.title contains 'Default' -%}
                  <p class="lsq-cart-variant">{{ item.variant.title }}</p>
                {%- endunless -%}
                <p class="lsq-cart-price-mobile">{{ item.final_line_price | money }}</p>
                <a href="{{ item.url_to_remove }}" class="lsq-cart-remove">{{ s.remove_label }}</a>
              </div>
              <div class="lsq-cart-qty">
                <label class="lsq-sr-only" for="updates_{{ item.index | plus: 1 }}">{{ s.qty_label }}</label>
                <input type="number" min="0" name="updates[]" id="updates_{{ item.index | plus: 1 }}" value="{{ item.quantity }}" inputmode="numeric" class="lsq-qty-input">
              </div>
              <div class="lsq-cart-line-price">{{ item.final_line_price | money }}</div>
            </div>
          {%- endfor -%}
        </div>

        <div class="lsq-cart-summary">
          <div class="lsq-cart-summary-row">
            <span>{{ s.subtotal_label }}</span>
            <strong>{{ cart.total_price | money }}</strong>
          </div>
          <p class="section-sub">{{ s.tax_note }}</p>
          <button type="submit" name="checkout" class="btn-primary lsq-checkout-btn">{{ s.checkout_label }}</button>
          <button type="submit" name="update" class="btn-outline lsq-update-btn">{{ s.update_label }}</button>
          <a href="{{ s.continue_link | default: routes.all_products_collection_url }}" class="btn-ghost lsq-continue">{{ s.continue_label }}</a>
        </div>
      </form>
    {%- else -%}
      <div class="lsq-cart-empty text-center">
        <p class="section-sub" style="margin-bottom:1.25rem;">{{ s.empty_text }}</p>
        <a href="{{ s.empty_link | default: routes.all_products_collection_url }}" class="btn-primary">{{ s.empty_button_label }}</a>
      </div>
    {%- endif -%}
  </div>
</section>

{% style %}
  #Sec--{{ section.id }} .lsq-cart { display:grid; grid-template-columns:1fr; gap:2rem; }
  @media (min-width:900px){ #Sec--{{ section.id }} .lsq-cart { grid-template-columns:2fr 1fr; align-items:start; } }
  #Sec--{{ section.id }} .lsq-cart-item {
    display:grid; grid-template-columns:88px 1fr auto; gap:1rem; align-items:center;
    padding:1rem 0; border-bottom:1px solid var(--gray-200,#e5e7eb);
  }
  #Sec--{{ section.id }} .lsq-cart-thumb img { width:88px; height:88px; object-fit:cover; border-radius:var(--radius,8px); }
  #Sec--{{ section.id }} .lsq-cart-title { font-weight:600; color:var(--brand-text); text-decoration:none; }
  #Sec--{{ section.id }} .lsq-cart-variant { color:var(--gray-500); font-size:0.875rem; margin-top:0.15rem; }
  #Sec--{{ section.id }} .lsq-cart-price-mobile { display:none; }
  #Sec--{{ section.id }} .lsq-cart-remove { display:inline-block; margin-top:0.35rem; font-size:0.8125rem; color:var(--brand-link,#268290); }
  #Sec--{{ section.id }} .lsq-qty-input {
    width:64px; padding:0.5rem; text-align:center; border:1px solid var(--gray-200,#e5e7eb); border-radius:var(--radius,8px);
  }
  #Sec--{{ section.id }} .lsq-cart-line-price { font-weight:700; text-align:right; }
  #Sec--{{ section.id }} .lsq-cart-summary {
    background:var(--gray-50,#f9fafb); border:1px solid var(--gray-200,#e5e7eb);
    border-radius:var(--radius,8px); padding:1.5rem; display:flex; flex-direction:column; gap:0.75rem;
  }
  #Sec--{{ section.id }} .lsq-cart-summary-row { display:flex; justify-content:space-between; font-size:1.125rem; }
  #Sec--{{ section.id }} .lsq-checkout-btn, #Sec--{{ section.id }} .lsq-update-btn, #Sec--{{ section.id }} .lsq-continue { width:100%; text-align:center; }
  #Sec--{{ section.id }} .lsq-cart-empty { padding:3rem 0; }
  #Sec--{{ section.id }} .lsq-sr-only { position:absolute; width:1px; height:1px; padding:0; margin:-1px; overflow:hidden; clip:rect(0,0,0,0); white-space:nowrap; border:0; }
  @media (max-width:640px){
    #Sec--{{ section.id }} .lsq-cart-item { grid-template-columns:72px 1fr; }
    #Sec--{{ section.id }} .lsq-cart-thumb img { width:72px; height:72px; }
    #Sec--{{ section.id }} .lsq-cart-line-price { display:none; }
    #Sec--{{ section.id }} .lsq-cart-price-mobile { display:block; font-weight:700; margin-top:0.35rem; }
    #Sec--{{ section.id }} .lsq-cart-qty { grid-column:2; }
  }
{% endstyle %}

<script>
  (function () {
    var form = document.getElementById('lsq-cart-form');
    if (!form) return;
    form.querySelectorAll('.lsq-qty-input').forEach(function (input) {
      input.addEventListener('change', function () {
        form.querySelector('.lsq-update-btn').click();
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Cart",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Your cart" },
    { "type": "text", "id": "subtotal_label", "label": "Subtotal label", "default": "Subtotal" },
    { "type": "text", "id": "tax_note", "label": "Tax note", "default": "Taxes and shipping calculated at checkout." },
    { "type": "text", "id": "qty_label", "label": "Quantity label", "default": "Quantity" },
    { "type": "text", "id": "remove_label", "label": "Remove label", "default": "Remove" },
    { "type": "text", "id": "checkout_label", "label": "Checkout button", "default": "Checkout" },
    { "type": "text", "id": "update_label", "label": "Update button", "default": "Update cart" },
    { "type": "text", "id": "continue_label", "label": "Continue link", "default": "Continue shopping" },
    { "type": "text", "id": "empty_text", "label": "Empty cart text", "default": "Your cart is empty right now." },
    { "type": "text", "id": "empty_button_label", "label": "Empty button label", "default": "Start shopping" },
    { "type": "url", "id": "continue_link", "label": "Continue shopping link" },
    { "type": "url", "id": "empty_link", "label": "Empty cart button link" }
  ],
  "presets": [
    { "name": "Cart" }
  ]
}
{% endschema %}
