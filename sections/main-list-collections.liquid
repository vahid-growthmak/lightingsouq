{%- comment -%}
  Collections index (/collections) — dynamic grid of every collection as a card.
  Reuses base.css .category-card. Editable heading/intro.
{%- endcomment -%}
<div class="collection-header">
  <div class="container">
    <h1 class="collection-title">{{ section.settings.heading }}</h1>
    {%- if section.settings.intro != blank -%}<p class="collection-intro">{{ section.settings.intro }}</p>{%- endif -%}
  </div>
</div>

<section class="section bg-white">
  <div class="container">
    <div class="grid-4">
      {%- assign sorted = collections | sort: 'title' -%}
      {%- for collection in sorted -%}
        {%- unless collection.handle == 'frontpage' -%}
          <a href="{{ collection.url }}" class="category-card">
            <div class="cat-img-wrap">
              <img src="{% if collection.image != blank %}{{ collection.image | image_url: width: 600 }}{% elsif collection.products.first.featured_image != blank %}{{ collection.products.first.featured_image | image_url: width: 600 }}{% elsif section.settings.fallback_image %}{{ section.settings.fallback_image | image_url: width: 600 }}{% else %}{{ 'space-home.png' | asset_url }}{% endif %}" alt="{{ collection.title | escape }}" width="600" height="600" loading="lazy" style="width:100%;height:100%;object-fit:cover;">
            </div>
            <div class="cat-body">
              <h3 class="cat-title">{{ collection.title }}</h3>
              <p class="cat-count">{{ collection.products_count }} {{ section.settings.label_products_word | default: 'products' | escape }}</p>
              <span class="cat-link">{{ section.settings.link_label }}</span>
            </div>
          </a>
        {%- endunless -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Collections Index",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shop by Collection" },
    { "type": "text", "id": "intro", "label": "Intro", "default": "Browse every lighting category and brand in one place." },
    { "type": "text", "id": "link_label", "label": "Card link label", "default": "Shop Now →" },
    { "type": "text", "id": "label_products_word", "label": "Products count word", "default": "products" },
    { "type": "image_picker", "id": "fallback_image", "label": "Fallback card image (if collection has no image)" }
  ],
  "presets": [
    { "name": "Collections Index" }
  ]
}
{% endschema %}
