{%- comment -%}
  Classic customer login + recover-password toggle. OS 2.0 main section.
{%- endcomment -%}
<div class="container" style="padding-top:1.25rem;">
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="{{ routes.root_url }}">Home</a> / <span>Login</span>
  </nav>
</div>

<section class="section">
  <div class="container lsq-auth" style="max-width:560px;">

    {%- comment -%} ===== LOGIN VIEW ===== {%- endcomment -%}
    <div id="login-view" class="lsq-auth-view">
      <h1 class="collection-title">Log in</h1>
      <p class="collection-intro">Access your Lighting Souq account, orders and addresses.</p>

      {%- form 'customer_login', novalidate: 'novalidate' -%}
        {%- if form.errors -%}
          <div class="form-errors">{{ form.errors | default_errors }}</div>
        {%- endif -%}

        <div class="lsq-field">
          <label for="customer_email">Email</label>
          <input type="email" name="customer[email]" id="customer_email" autocomplete="email" autocorrect="off" autocapitalize="off" required>
        </div>

        {%- if form.password_needed -%}
          <div class="lsq-field">
            <label for="customer_password">Password</label>
            <input type="password" name="customer[password]" id="customer_password" autocomplete="current-password" required>
          </div>
        {%- endif -%}

        <button type="submit" class="btn-primary lsq-btn-full">Log in</button>

        <p class="lsq-alt">
          <a href="#recover" onclick="document.getElementById('login-view').style.display='none';document.getElementById('recover-view').style.display='block';return false;">Forgot your password?</a>
        </p>
        <p class="lsq-alt">New to Lighting Souq? <a href="{{ routes.account_register_url }}">Create an account</a></p>
      {%- endform -%}
    </div>

    {%- comment -%} ===== RECOVER PASSWORD VIEW ===== {%- endcomment -%}
    <div id="recover-view" class="lsq-auth-view" style="display:none;">
      <h1 class="collection-title">Reset your password</h1>
      <p class="collection-intro">Enter your email and we'll send you a reset link.</p>

      {%- form 'recover_customer_password' -%}
        {%- if form.errors -%}
          <div class="form-errors">{{ form.errors | default_errors }}</div>
        {%- endif -%}
        {%- if form.posted_successfully? -%}
          <div class="form-success">We've sent you an email with a link to update your password.</div>
        {%- endif -%}

        <div class="lsq-field">
          <label for="recover_email">Email</label>
          <input type="email" name="email" id="recover_email" autocomplete="email" autocorrect="off" autocapitalize="off" required>
        </div>

        <button type="submit" class="btn-primary lsq-btn-full">Send reset link</button>

        <p class="lsq-alt">
          <a href="#login" onclick="document.getElementById('recover-view').style.display='none';document.getElementById('login-view').style.display='block';return false;">Back to log in</a>
        </p>
      {%- endform -%}
    </div>

  </div>
</section>

<script>
  // If the recover form was submitted (successfully or with errors), keep it open.
  if (window.location.hash === '#recover') {
    var lv = document.getElementById('login-view');
    var rv = document.getElementById('recover-view');
    if (lv && rv) { lv.style.display = 'none'; rv.style.display = 'block'; }
  }
</script>

<style>
  .lsq-auth .lsq-field { margin-bottom: 1rem; }
  .lsq-auth label { display:block; font-weight:600; margin-bottom:0.4rem; font-size:0.9rem; color: var(--brand-text, #333); }
  .lsq-auth input[type="email"],
  .lsq-auth input[type="password"],
  .lsq-auth input[type="text"] {
    width:100%; padding:0.7rem 0.9rem; border:1px solid #e5e7eb;
    border-radius: var(--radius, 10px); font-size:1rem; box-sizing:border-box;
    background:#fff; color: var(--brand-text, #333);
  }
  .lsq-auth input:focus { outline:2px solid var(--brand-primary, #2B60AD); outline-offset:1px; border-color: var(--brand-primary, #2B60AD); }
  .lsq-auth .lsq-btn-full { width:100%; margin-top:0.5rem; }
  .lsq-auth .lsq-alt { margin-top:1rem; font-size:0.9rem; color:#6b7280; }
  .lsq-auth .lsq-alt a { color: var(--brand-primary, #2B60AD); font-weight:600; text-decoration:none; }
  .lsq-auth .lsq-alt a:hover { text-decoration:underline; }
  .lsq-auth .form-errors {
    background:#fef2f2; border:1px solid #fecaca; color:#b91c1c;
    padding:0.85rem 1rem; border-radius: var(--radius, 10px); margin-bottom:1.25rem; font-size:0.9rem;
  }
  .lsq-auth .form-errors ul { margin:0; padding-left:1.1rem; }
  .lsq-auth .form-success {
    background:#ecfdf5; border:1px solid #a7f3d0; color:#047857;
    padding:0.85rem 1rem; border-radius: var(--radius, 10px); margin-bottom:1.25rem; font-size:0.9rem;
  }
</style>

{% schema %}
{
  "name": "Customer login",
  "tag": "section",
  "settings": []
}
{% endschema %}
