{%- comment -%}
  PDP core — renders per-product custom metafields (specifications, delivery, pickup) dynamically. v3 (resync)
  Main product — PDP core. Replicates the mockup as an editable TEMPLATE: title,
  price, compare-at, images, variants and description come from the real product;
  rating, sold count, stock urgency, specs, delivery copy etc. are editable
  placeholder values that always render (like the mockup) so the merchant fills them
  in. Real reviews metafield / real inventory override the placeholders when present.
  Shopify-safe schema (names <=25 chars, no empty/url/step violations, plain product form).
  Stock is live from inventory; viewers & sold are editable toggles (OFF by default).
{%- endcomment -%}
{%- liquid
  assign s = section.settings
  assign cur = product.selected_or_first_available_variant
  assign on_sale = false
  if cur.compare_at_price > cur.price
    assign on_sale = true
  endif
  assign rating = product.metafields.reviews.rating.value | default: s.fallback_rating
  assign review_count = product.metafields.reviews.rating_count.value | default: s.fallback_reviews
  assign specs = product.metafields.custom.specs.value
  assign bc = blank
  comment
    Prefer the collection matching the product TYPE (e.g. "Grow Lights"), so the
    category crumb is meaningful and never duplicates the vendor crumb below.
  endcomment
  for c in product.collections
    if c.handle != 'frontpage' and c.title == product.type
      assign bc = c
      break
    endif
  endfor
  if bc == blank
    for c in product.collections
      if c.handle != 'frontpage' and c.title != product.vendor and bc == blank
        assign bc = c
      endif
    endfor
  endif
  if bc == blank
    for c in product.collections
      if c.handle != 'frontpage' and bc == blank
        assign bc = c
      endif
    endfor
  endif
-%}

<section class="section" style="padding-top:1.25rem;" id="MainProduct--{{ section.id }}">
  <div class="container">

    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="{{ routes.root_url }}">{{ s.label_home | default: 'Home' | escape }}</a>
      {%- if bc != blank %} / <a href="{{ bc.url }}">{{ bc.title }}</a>{% elsif product.type != blank %} / <a href="{{ routes.all_products_collection_url }}">{{ product.type }}</a>{% endif -%}
      {%- if product.vendor != blank and product.vendor != bc.title %} / <a href="{{ product.vendor | url_for_vendor }}">{{ product.vendor }}</a>{% endif %} /
      <span>{{ product.title }}</span>
    </nav>

    <div class="pdp-layout">
      <div class="pdp-gallery">
        <div class="pdp-main-img">
          {%- if on_sale -%}
            {%- assign pct = cur.compare_at_price | minus: cur.price | times: 100.0 | divided_by: cur.compare_at_price | round -%}
            <span class="pdp-gallery-badge">{{ s.label_save | default: 'Save' | escape }} {{ pct }}%</span>
          {%- endif -%}
          <div class="pdp-gallery-tools">
            <button class="pdp-tool-btn" type="button" aria-label="{{ settings.aria_add_wishlist | default: 'Add to wishlist' | escape }}" data-wishlist-toggle
              data-handle="{{ product.handle }}"
              data-id="{{ product.id }}"
              data-variant="{{ cur.id }}"
              data-available="{{ product.available }}"
              data-title="{{ product.title | escape }}"
              data-url="{{ product.url }}"
              data-image="{% if product.featured_image != blank %}{{ product.featured_image | image_url: width: 400 }}{% elsif settings.default_product_image != blank %}{{ settings.default_product_image | image_url: width: 400 }}{% else %}{{ 'prod-bulb.png' | asset_url }}{% endif %}"
              data-price="{{ cur.price | money }}"><span class="material-symbols-outlined">favorite</span></button>
            <button class="pdp-tool-btn" type="button" aria-label="{{ s.label_share | default: 'Share' | escape }}" data-share><span class="material-symbols-outlined">share</span></button>
          </div>
          <img id="MainImg--{{ section.id }}" src="{% if product.featured_image %}{{ product.featured_image | image_url: width: 900 }}{% elsif settings.default_product_image != blank %}{{ settings.default_product_image | image_url: width: 900 }}{% else %}{{ 'prod-bulb.png' | asset_url }}{% endif %}" alt="{{ product.featured_image.alt | default: product.title | escape }}" width="900" height="900">
        </div>
        {%- if product.images.size > 1 -%}
          <div class="pdp-thumbs">
            {%- for image in product.images limit: 6 -%}
              <div class="pdp-thumb{% if forloop.first %} active{% endif %}" data-thumb="{{ image | image_url: width: 900 }}">
                <img src="{{ image | image_url: width: 160 }}" alt="{{ product.title | escape }} view {{ forloop.index }}" width="160" height="160" loading="lazy">
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      <div class="buy-box">
        {%- if product.vendor != blank -%}<p class="pdp-vendor">{{ product.vendor }}</p>{%- endif -%}
        <h1 class="pdp-title">{{ product.title }}</h1>

        <div class="pdp-rating-row">
          {%- assign g_rating = settings.google_rating | default: rating -%}
          <div class="stars">{% render 'rating-stars', rating: g_rating %}</div>
          <a href="{{ settings.google_reviews_url | default: '#reviews' }}"{% if settings.google_reviews_url != blank %} target="_blank" rel="noopener nofollow"{% endif %} class="pdp-rating-link">{{ g_rating }} · {{ settings.google_count | default: review_count }} {{ settings.google_reviews_label | default: 'Google reviews' | escape }}</a>
          {%- if s.show_sold -%}
            {%- assign sold_val = product.metafields.custom.sold.value | default: s.sold_count -%}
            {%- if sold_val != blank -%}<span class="pdp-sold">· {{ sold_val }} {{ s.label_sold | default: 'sold' | escape }}</span>{%- endif -%}
          {%- endif -%}
        </div>

        <div class="pdp-price-row">
          <span class="pdp-new-price" data-price>{{ cur.price | money }}</span>
          {%- if on_sale -%}
            <span class="pdp-old-price">{{ cur.compare_at_price | money }}</span>
            {%- assign pct = cur.compare_at_price | minus: cur.price | times: 100.0 | divided_by: cur.compare_at_price | round -%}
            <span class="pdp-discount">-{{ pct }}%</span>
          {%- endif -%}
        </div>
        {%- if on_sale -%}<p class="pdp-save">{{ s.label_you_save | default: 'You save' | escape }} {{ cur.compare_at_price | minus: cur.price | money }} {{ s.label_today | default: 'today' | escape }}</p>{%- endif -%}
        {%- if s.tax_note != blank -%}<p class="pdp-tax-note">{{ s.tax_note }}</p>{%- endif -%}

        {%- if s.show_urgency -%}
          {%- liquid
            comment Real inventory-driven stock status. endcomment
            assign threshold = s.low_stock_threshold | default: 10
            assign tracked = false
            if cur.inventory_management != blank
              assign tracked = true
            endif
            assign qty = cur.inventory_quantity
            assign is_low = false
            assign bar_pct = 100
            if tracked and qty > 0 and qty <= threshold
              assign is_low = true
              assign bar_pct = qty | times: 100 | divided_by: threshold
            endif
          -%}
          {%- if product.available -%}
            <div class="pdp-stock-row">
              {%- if is_low -%}
                <span class="pdp-stock low"><span class="dot"></span> {{ s.stock_low_pre | default: 'Only' | escape }} {{ qty }} {{ s.stock_low_post | default: 'left in stock' | escape }}</span>
              {%- else -%}
                <span class="pdp-stock in"><span class="dot"></span> {{ s.stock_in | default: 'In stock' | escape }}</span>
              {%- endif -%}
              {%- if s.show_viewers and s.viewers != blank -%}<span class="pdp-viewers"><span class="material-symbols-outlined">visibility</span> {{ s.viewers }} {{ s.label_viewers | default: 'people viewing now' | escape }}</span>{%- endif -%}
            </div>
            {%- if is_low -%}<div class="pdp-stock-bar"><span style="width:{{ bar_pct }}%"></span></div>{%- endif -%}
          {%- else -%}
            <div class="pdp-stock-row"><span class="pdp-stock out"><span class="dot"></span> {{ s.stock_out | default: 'Out of stock' | escape }}</span></div>
          {%- endif -%}
        {%- endif -%}

        <form method="post" action="{{ routes.cart_add_url }}" id="ProductForm--{{ section.id }}" class="pdp-form" accept-charset="UTF-8" enctype="multipart/form-data" data-cart-form>
          <input type="hidden" name="form_type" value="product">
          <input type="hidden" name="utf8" value="✓">

          {%- unless product.has_only_default_variant -%}
            <div class="pdp-options">
              {%- for option in product.options_with_values -%}
                <span class="option-label">{{ option.name }}</span>
                <div class="option-grid" data-option-index="{{ forloop.index0 }}">
                  {%- for value in option.values -%}
                    <button class="option-btn{% if option.selected_value == value %} active{% endif %}" type="button" data-option-value="{{ value | escape }}">{{ value }}</button>
                  {%- endfor -%}
                </div>
              {%- endfor -%}
            </div>
          {%- endunless -%}

          <input type="hidden" name="id" value="{{ cur.id }}" data-variant-id>

          <div class="pdp-actions">
            <div class="pdp-qty-cta">
              <div class="qty-control">
                <button type="button" data-qty-minus aria-label="{{ s.label_decrease | default: 'Decrease' | escape }}">−</button>
                <span data-qty>1</span>
                <button type="button" data-qty-plus aria-label="{{ s.label_increase | default: 'Increase' | escape }}">+</button>
              </div>
              <input type="hidden" name="quantity" value="1" data-qty-input>
              <button class="btn-atc" type="submit" data-atc {% unless cur.available %}disabled{% endunless %}>{% if cur.available %}{{ s.label_add_cart | default: 'ADD TO CART' | escape }}{% else %}{{ s.label_sold_out_pdp | default: 'SOLD OUT' | escape }}{% endif %}</button>
            </div>
            {%- if cur.available -%}<button class="btn-buy-now" type="submit" name="checkout" data-buy-now>{{ s.label_buy_now | default: 'BUY IT NOW' | escape }}</button>{%- endif -%}
            {%- if s.show_bulk -%}<a class="btn-quote-lg rbo-open" href="{{ s.bulk_link | default: routes.root_url }}"
              data-variant-id="{{ cur.id }}"
              data-title="{{ product.title | escape }}"
              data-variant="{{ cur.title | escape }}"
              data-sku="{{ cur.sku }}"
              data-handle="{{ product.handle }}"
              data-price="{{ cur.price | money }}"
              data-image="{% if product.featured_image != blank %}{{ product.featured_image | image_url: width: 96 }}{% endif %}"><span class="material-symbols-outlined" style="font-size:1.1rem;">request_quote</span> {{ s.bulk_label }}</a>{%- endif -%}
          </div>
        </form>

        <div class="pdp-pay-under">
          <span class="pdp-pay-label"><strong>{{ s.label_pay | default: 'Pay your way' | escape }}</strong>{% if s.pay_note != blank %} — {{ s.pay_note }}{% endif %}</span>
          <div class="pay-methods">
            {%- assign has_pay = false -%}
            {%- for block in section.blocks -%}{%- if block.type == 'payment' -%}{%- assign has_pay = true -%}{%- endif -%}{%- endfor -%}
            {%- if has_pay -%}
              {%- for block in section.blocks -%}{%- if block.type == 'payment' -%}{% render 'payment-icon', label: block.settings.method %}{%- endif -%}{%- endfor -%}
            {%- else -%}
              {%- render 'payment-icon', label: 'Visa' -%}
              {%- render 'payment-icon', label: 'Mastercard' -%}
              {%- render 'payment-icon', label: 'Apple Pay' -%}
              {%- render 'payment-icon', label: 'Cash on Delivery' -%}
            {%- endif -%}
          </div>
        </div>

        <div class="pdp-assurance">
          {%- if s.assure_1 != blank -%}<div class="pdp-assure-item"><span class="material-symbols-outlined">local_shipping</span><span>{{ s.assure_1 }}</span></div>{%- endif -%}
          {%- if s.assure_2 != blank -%}<div class="pdp-assure-item"><span class="material-symbols-outlined">verified_user</span><span>{{ s.assure_2 }}</span></div>{%- endif -%}
          {%- assign mf_trust = product.metafields.custom.trust.value -%}
          {%- if mf_trust != blank -%}<div class="pdp-assure-item"><span class="material-symbols-outlined">workspace_premium</span><span>{{ mf_trust | strip_html }}</span></div>{%- endif -%}
        </div>
      </div>
    </div>

    <div class="pdp-accordions">
      <div class="collapsible-row active">
        <button class="collapsible-trigger" type="button" data-accordion>{{ s.label_description | default: 'Description' | escape }} <span class="material-symbols-outlined">expand_more</span></button>
        <div class="collapsible-content"><div class="pdp-desc">{% if product.description != blank %}{{ product.description }}{% else %}{{ s.fallback_desc }}{% endif %}</div></div>
      </div>

      <div class="collapsible-row" id="specs">
        <button class="collapsible-trigger" type="button" data-accordion>{{ s.label_specs | default: 'Key Specifications' | escape }} <span class="material-symbols-outlined">expand_more</span></button>
        <div class="collapsible-content">
          {%- assign specs_mf = product.metafields.custom.specifications.value -%}
          <div class="spec-grid">
            {%- if specs_mf != blank and specs_mf contains '<tr' -%}
              {%- comment -%} Per-product specs from HTML table metafield — <tr><td>Key</td><td>Value</td></tr> rows rendered as native spec rows {%- endcomment -%}
              {%- assign spec_rows = specs_mf | split: '<tr>' -%}
              {%- for row in spec_rows offset: 1 -%}
                {%- assign cells = row | split: '</td>' -%}
                {%- assign sk = cells[0] | strip_html | strip -%}
                {%- assign sv = cells[1] | strip_html | strip -%}
                {%- if sk != blank and sv != blank -%}
                  <div class="spec-item"><span class="spec-key"><span class="material-symbols-outlined">check</span>{{ sk }}</span><span class="spec-val">{{ sv }}</span></div>
                {%- endif -%}
              {%- endfor -%}
            {%- elsif specs_mf != blank -%}
              {%- comment -%} Per-product specs from metafield "Key: Value" per line — native spec rows {%- endcomment -%}
              {%- assign spec_rows = specs_mf | strip | newline_to_br | split: '<br />' -%}
              {%- for row in spec_rows -%}
                {%- assign row = row | strip -%}
                {%- if row contains ':' -%}
                  {%- assign sk = row | split: ':' | first | strip -%}
                  {%- assign sv = row | remove_first: sk | remove_first: ':' | strip -%}
                  <div class="spec-item"><span class="spec-key"><span class="material-symbols-outlined">check</span>{{ sk }}</span><span class="spec-val">{{ sv }}</span></div>
                {%- endif -%}
              {%- endfor -%}
            {%- elsif specs != blank -%}
              {%- for row in specs -%}
                {%- assign parts = row | split: '|' -%}
                <div class="spec-item"><span class="spec-key"><span class="material-symbols-outlined">check</span>{{ parts[0] | strip }}</span><span class="spec-val">{{ parts[1] | default: parts[0] | strip }}</span></div>
              {%- endfor -%}
            {%- else -%}
              {%- for block in section.blocks -%}
                {%- if block.type == 'spec' -%}
                  <div class="spec-item" {{ block.shopify_attributes }}><span class="spec-key"><span class="material-symbols-outlined">{{ block.settings.icon }}</span>{{ block.settings.key }}</span><span class="spec-val">{{ block.settings.value }}</span></div>
                {%- endif -%}
              {%- endfor -%}
            {%- endif -%}
          </div>
        </div>
      </div>

      {%- assign mf_delivery = product.metafields.custom.delivery.value -%}
      {%- assign mf_pickup = product.metafields.custom.pickup.value -%}
      {%- if mf_delivery != blank or mf_pickup != blank or s.delivery_content != blank -%}
        <div class="collapsible-row">
          <button class="collapsible-trigger" type="button" data-accordion>{{ s.label_delivery | default: 'Delivery &amp; Pick-up' }} <span class="material-symbols-outlined">expand_more</span></button>
          <div class="collapsible-content"><div class="delivery-content">
            {%- if mf_delivery != blank or mf_pickup != blank -%}
              {%- if mf_delivery != blank -%}<div class="pdp-dp-block"><strong>Delivery</strong><p>{{ mf_delivery | newline_to_br }}</p></div>{%- endif -%}
              {%- if mf_pickup != blank -%}<div class="pdp-dp-block"><strong>Pickup</strong><p>{{ mf_pickup | newline_to_br }}</p></div>{%- endif -%}
            {%- else -%}
              {{ s.delivery_content }}
            {%- endif -%}
          </div></div>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

<div class="sticky-atc" data-sticky>
  <div class="container sticky-atc-inner">
    <div class="sticky-atc-left">
      <img class="sticky-atc-thumb" src="{% if product.featured_image %}{{ product.featured_image | image_url: width: 120 }}{% elsif settings.default_product_image != blank %}{{ settings.default_product_image | image_url: width: 120 }}{% else %}{{ 'prod-bulb.png' | asset_url }}{% endif %}" alt="{{ product.title | escape }}" width="60" height="60">
      <div class="sticky-atc-info">
        <div class="sticky-atc-title">{{ product.title }}</div>
        <div class="sticky-atc-meta">
          <span class="sticky-atc-price">{{ cur.price | money }}</span>
          {%- if on_sale -%}<span class="sticky-atc-old">{{ cur.compare_at_price | money }}</span>{%- endif -%}
        </div>
      </div>
    </div>
    <div class="sticky-atc-actions">
      <button class="btn-atc" type="button" data-sticky-atc {% unless cur.available %}disabled{% endunless %}>{% if cur.available %}{{ s.label_add_cart_sticky | default: 'Add to Cart' | escape }}{% else %}{{ s.label_sold_sticky | default: 'Sold Out' | escape }}{% endif %}</button>
      {%- if cur.available -%}<button class="btn-buy-now" type="button" data-sticky-buy>{{ s.label_buy_sticky | default: 'Buy it Now' | escape }}</button>{%- endif -%}
    </div>
  </div>
</div>

<script>
  (function () {
    var root = document.getElementById('MainProduct--{{ section.id }}');
    if (!root) return;
    var variants = {{ product.variants | json }};
    var optionGrids = root.querySelectorAll('.option-grid');
    var idInput = root.querySelector('[data-variant-id]');
    var priceEl = root.querySelector('[data-price]');
    var atc = root.querySelector('[data-atc]');
    var form = root.querySelector('.pdp-form');
    var moneyFormat = {{ shop.money_format | json }};
    var L_ATC = {{ s.label_add_cart | default: 'ADD TO CART' | json }};
    var L_SOLD = {{ s.label_sold_out_pdp | default: 'SOLD OUT' | json }};
    function money(cents) {
      var v = (cents / 100).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
      return moneyFormat.replace(/\{\{\s*amount\s*\}\}/, v);
    }
    function selectedOptions() {
      var opts = [];
      optionGrids.forEach(function (g) {
        var a = g.querySelector('.option-btn.active');
        opts[parseInt(g.getAttribute('data-option-index'), 10)] = a ? a.getAttribute('data-option-value') : null;
      });
      return opts;
    }
    function updateVariant() {
      var sel = selectedOptions();
      var match = variants.find(function (v) { return v.options.every(function (o, i) { return o === sel[i]; }); });
      if (!match) return;
      if (idInput) idInput.value = match.id;
      if (priceEl) priceEl.textContent = money(match.price);
      if (atc) { atc.disabled = !match.available; atc.textContent = match.available ? L_ATC : L_SOLD; }
    }
    optionGrids.forEach(function (g) {
      g.querySelectorAll('.option-btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
          g.querySelectorAll('.option-btn').forEach(function (b) { b.classList.remove('active'); });
          btn.classList.add('active');
          updateVariant();
        });
      });
    });
    var mainImg = document.getElementById('MainImg--{{ section.id }}');
    root.querySelectorAll('.pdp-thumb').forEach(function (t) {
      t.addEventListener('click', function () {
        root.querySelectorAll('.pdp-thumb').forEach(function (x) { x.classList.remove('active'); });
        t.classList.add('active');
        if (mainImg) mainImg.src = t.getAttribute('data-thumb');
      });
    });
    var qtyEl = root.querySelector('[data-qty]');
    var qtyInput = root.querySelector('[data-qty-input]');
    var qty = 1;
    function setQty(n) { qty = Math.max(1, n); if (qtyEl) qtyEl.textContent = qty; if (qtyInput) qtyInput.value = qty; }
    var minus = root.querySelector('[data-qty-minus]'); var plus = root.querySelector('[data-qty-plus]');
    if (minus) minus.addEventListener('click', function () { setQty(qty - 1); });
    if (plus) plus.addEventListener('click', function () { setQty(qty + 1); });
    root.querySelectorAll('[data-accordion]').forEach(function (b) {
      b.addEventListener('click', function () { b.parentElement.classList.toggle('active'); });
    });
    var share = root.querySelector('[data-share]');
    if (share) share.addEventListener('click', function () {
      if (navigator.share) { navigator.share({ title: document.title, url: location.href }).catch(function(){}); }
      else if (navigator.clipboard) { navigator.clipboard.writeText(location.href); }
    });
    var sticky = document.querySelector('[data-sticky]');
    var actions = root.querySelector('.pdp-actions');
    if (sticky && actions) {
      new IntersectionObserver(function (e) { sticky.classList.toggle('show', !e[0].isIntersecting); }, { threshold: 0 }).observe(actions);
      var stickyBtn = sticky.querySelector('[data-sticky-atc]');
      if (stickyBtn && form) stickyBtn.addEventListener('click', function () { form.requestSubmit ? form.requestSubmit() : form.submit(); });
      var stickyBuy = sticky.querySelector('[data-sticky-buy]');
      var buyNow = root.querySelector('[data-buy-now]');
      if (stickyBuy && buyNow) stickyBuy.addEventListener('click', function () { buyNow.click(); });
      document.body.classList.add('has-sticky-atc');
    }
  })();
</script>

{% schema %}
{
  "name": "Product",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Labels & wording" },
    { "type": "text", "id": "label_home", "label": "Breadcrumb home", "default": "Home" },
    { "type": "text", "id": "label_save", "label": "Save badge word", "default": "Save" },
    { "type": "text", "id": "label_share", "label": "Share button label", "default": "Share" },
    { "type": "text", "id": "label_sold", "label": "'sold' word", "default": "sold" },
    { "type": "text", "id": "label_you_save", "label": "'You save' text", "default": "You save" },
    { "type": "text", "id": "label_today", "label": "'today' word", "default": "today" },
    { "type": "text", "id": "stock_low_pre", "label": "Low stock prefix", "default": "Only" },
    { "type": "text", "id": "stock_low_post", "label": "Low stock suffix", "default": "left in stock" },
    { "type": "text", "id": "stock_in", "label": "In stock text", "default": "In stock" },
    { "type": "text", "id": "stock_out", "label": "Out of stock text", "default": "Out of stock" },
    { "type": "text", "id": "label_viewers", "label": "'people viewing now' text", "default": "people viewing now" },
    { "type": "text", "id": "label_decrease", "label": "Qty decrease label", "default": "Decrease" },
    { "type": "text", "id": "label_increase", "label": "Qty increase label", "default": "Increase" },
    { "type": "text", "id": "label_add_cart", "label": "Add to cart button", "default": "ADD TO CART" },
    { "type": "text", "id": "label_sold_out_pdp", "label": "Sold out button", "default": "SOLD OUT" },
    { "type": "text", "id": "label_buy_now", "label": "Buy it now button", "default": "BUY IT NOW" },
    { "type": "text", "id": "label_add_cart_sticky", "label": "Sticky add to cart", "default": "Add to Cart" },
