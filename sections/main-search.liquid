{%- comment -%}
  Search results — OS 2.0. Search form, result count, paginated grid of
  products (via product-card) and other result types as simple link cards.
{%- endcomment -%}
{%- liquid
  assign s = section.settings
-%}
<section class="section bg-white" id="Sec--{{ section.id }}" aria-labelledby="search-heading">
  <div class="container">
    <div class="section-header">
      <div>
        <h1 class="section-title" id="search-heading">{{ s.heading }}</h1>
        {%- if s.subtext != blank -%}<p class="section-sub">{{ s.subtext }}</p>{%- endif -%}
      </div>
    </div>

    <form action="{{ routes.search_url }}" method="get" role="search" class="lsq-search-form">
      <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="{{ s.placeholder }}" aria-label="{{ s.placeholder }}" class="lsq-search-input">
      <button type="submit" class="btn-primary">{{ s.button_label }}</button>
    </form>

    {%- if search.performed -%}
      {%- if search.results_count > 0 -%}
        <p class="result-count" style="margin:1.25rem 0;">
          <strong>{{ search.results_count }}</strong> {{ s.results_word }} <em>{{ search.terms | escape }}</em>
        </p>
        {%- paginate search.results by 24 -%}
          <div class="grid-4">
            {%- for item in search.results -%}
              {%- if item.object_type == 'product' -%}
                {% render 'product-card', product: item %}
              {%- else -%}
                <a class="category-card lsq-result-card" href="{{ item.url }}">
                  <div class="cat-body">
                    <h3 class="cat-title">{{ item.title }}</h3>
                  </div>
                </a>
              {%- endif -%}
            {%- endfor -%}
          </div>

          {%- if paginate.pages > 1 -%}
            <nav class="pagination" aria-label="Pagination">
              {%- if paginate.previous -%}<a class="page-btn" href="{{ paginate.previous.url }}" aria-label="Previous">‹</a>{%- else -%}<button class="page-btn" disabled aria-label="Previous">‹</button>{%- endif -%}
              {%- for part in paginate.parts -%}
                {%- if part.is_link -%}<a class="page-btn" href="{{ part.url }}">{{ part.title }}</a>
                {%- elsif part.title == paginate.current_page -%}<button class="page-btn active">{{ part.title }}</button>
                {%- else -%}<span class="page-btn">{{ part.title }}</span>{%- endif -%}
              {%- endfor -%}
              {%- if paginate.next -%}<a class="page-btn" href="{{ paginate.next.url }}" aria-label="Next">›</a>{%- else -%}<button class="page-btn" disabled aria-label="Next">›</button>{%- endif -%}
            </nav>
          {%- endif -%}
        {%- endpaginate -%}
      {%- else -%}
        <div class="lsq-search-empty text-center">
          <p class="section-sub" style="margin-bottom:1.25rem;">{{ s.empty_text }}</p>
          <a href="{{ s.empty_link | default: routes.all_products_collection_url }}" class="btn-primary">{{ s.empty_button_label }}</a>
        </div>
      {%- endif -%}
    {%- else -%}
      <div class="lsq-search-empty text-center">
        <p class="section-sub" style="margin-bottom:1.25rem;">{{ s.prompt_text }}</p>
        <a href="{{ s.empty_link | default: routes.all_products_collection_url }}" class="btn-primary">{{ s.empty_button_label }}</a>
      </div>
    {%- endif -%}
  </div>
</section>

{% style %}
  #Sec--{{ section.id }} .lsq-search-form { display:flex; gap:0.5rem; max-width:640px; margin-bottom:0.5rem; }
  #Sec--{{ section.id }} .lsq-search-input {
    flex:1; padding:0.75rem 1rem; border:1px solid var(--gray-200,#e5e7eb);
    border-radius:var(--radius,8px); font-size:1rem;
  }
  #Sec--{{ section.id }} .lsq-search-input:focus { outline:2px solid var(--brand-primary); outline-offset:1px; }
  #Sec--{{ section.id }} .lsq-result-card { display:block; text-decoration:none; }
  #Sec--{{ section.id }} .lsq-search-empty { padding:3rem 0; }
{% endstyle %}

{% schema %}
{
  "name": "Search Results",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Search" },
    { "type": "text", "id": "subtext", "label": "Subtext", "default": "Find lights, bulbs, fixtures and more." },
    { "type": "text", "id": "placeholder", "label": "Input placeholder", "default": "Search the store" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Search" },
    { "type": "text", "id": "results_word", "label": "Results word", "default": "results for" },
    { "type": "text", "id": "prompt_text", "label": "Prompt text", "default": "Type a keyword above to start searching." },
    { "type": "text", "id": "empty_text", "label": "No results text", "default": "No matches found. Try another keyword or browse everything." },
    { "type": "text", "id": "empty_button_label", "label": "Empty button label", "default": "Browse all products" },
    { "type": "url", "id": "empty_link", "label": "Empty/prompt button link" }
  ],
  "presets": [
    { "name": "Search Results" }
  ]
}
{% endschema %}
