{%- liquid
  assign heading = section.settings.heading | default: page.title
  assign bg = section.settings.bg
-%}
{%- style -%}
  #PH--{{ section.id }} { position: relative; }
  #PH--{{ section.id }} .ph-inner { max-width: 760px; }
  #PH--{{ section.id }} .ph-title { font-size: 2rem; font-weight: 800; line-height: 1.15; color: var(--brand-text); margin: 0; }
  #PH--{{ section.id }} .ph-sub { color: var(--gray-500); font-size: 1.05rem; margin-top: 0.75rem; line-height: 1.6; }
  {%- if section.settings.image != blank -%}
  #PH--{{ section.id }} { background-image: linear-gradient(90deg, rgba(0,0,0,.55), rgba(0,0,0,.15)), url({{ section.settings.image | image_url: width: 1600 }}); background-size: cover; background-position: center; }
  #PH--{{ section.id }} .ph-title, #PH--{{ section.id }} .ph-sub { color: #fff; }
  {%- endif -%}
  @media (min-width: 768px) { #PH--{{ section.id }} .ph-title { font-size: 2.6rem; } }
{%- endstyle -%}
<section class="section {{ bg }}" id="PH--{{ section.id }}">
  <div class="container">
    <div class="ph-inner">
      <h1 class="ph-title">{{ heading }}</h1>
      {%- if section.settings.subtitle != blank -%}
        <p class="ph-sub">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Page Hero",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading (defaults to page title)" },
    { "type": "textarea", "id": "subtitle", "label": "Subtitle" },
    { "type": "image_picker", "id": "image", "label": "Background image (optional)" },
    {
      "type": "select",
      "id": "bg",
      "label": "Background",
      "options": [
        { "value": "bg-white", "label": "White" },
        { "value": "bg-gray", "label": "Gray" }
      ],
      "default": "bg-gray"
    }
  ],
  "presets": [
    { "name": "Page Hero" }
  ]
}
{% endschema %}
