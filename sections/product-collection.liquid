{%- liquid
  assign bg = section.settings.bg
  assign heading = section.settings.heading
  assign subtitle = section.settings.subtitle
  assign center = section.settings.center
  assign grid_class = section.settings.grid_class
  assign show_countdown = section.settings.show_countdown
  assign col = collections[section.settings.collection]
  assign ctx = section.settings.context | default: 'none'
  if ctx == 'none'
    assign ctx = ''
  endif
  if ctx != blank and product != blank
    if ctx == 'vendor'
      assign ctx_handle = product.vendor | handleize
    else
      assign ctx_handle = product.type | handleize
    endif
    assign ctx_col = collections[ctx_handle]
    if ctx_col.products.size > 1
      assign col = ctx_col
    elsif product.collections.size > 0
      assign col = product.collections.first
    endif
  endif
  assign use_dynamic = false
  if col.products.size > 0
    assign use_dynamic = true
  endif
  assign layout = section.settings.layout | default: 'scroll'
-%}
{%- liquid
  comment
    Context mode on a product page must never fall back to demo cards - hide instead.
  endcomment
  assign hide_section = false
  if ctx != blank and use_dynamic == false
    assign hide_section = true
  endif
-%}
{%- unless hide_section -%}
{%- style -%}
  #PC--{{ section.id }} .pc-container { position: relative; }
  #PC--{{ section.id }} .pc-scroll { display: flex; gap: 1.5rem; overflow-x: auto; scroll-snap-type: x proximity; scroll-behavior: smooth; padding: 6px 2px 1.25rem; scrollbar-width: none; -webkit-overflow-scrolling: touch; }
  #PC--{{ section.id }} .pc-scroll::-webkit-scrollbar { display: none; }
  #PC--{{ section.id }} .pc-scroll > * { flex: 0 0 clamp(230px, 24%, 280px); scroll-snap-align: start; }
  #PC--{{ section.id }} .pc-arrow { position: absolute; top: 42%; z-index: 6; width: 46px; height: 46px; border-radius: 50%; border: 1px solid #e5e7eb; background: #fff; box-shadow: 0 6px 20px rgba(0,0,0,.14); cursor: pointer; display: none; align-items: center; justify-content: center; color: var(--brand-primary); transition: all .15s ease-out; }
  #PC--{{ section.id }} .pc-arrow:hover { background: var(--brand-primary); color: #fff; border-color: var(--brand-primary); }
  #PC--{{ section.id }} .pc-arrow svg { width: 22px; height: 22px; }
  #PC--{{ section.id }} .pc-prev { left: -8px; }
  #PC--{{ section.id }} .pc-next { right: -8px; }
  @media (min-width: 1024px) { #PC--{{ section.id }} .pc-has-scroll .pc-arrow { display: inline-flex; } }
{%- endstyle -%}
<section class="section {{ bg }}" id="PC--{{ section.id }}">
  <div class="container">
    <div class="section-header">
      <div>
        <h2 class="section-title{% if center %} text-center{% endif %}">{{ heading }}</h2>
        {% if subtitle != blank %}<p class="section-sub">{{ subtitle }}</p>{% endif %}
      </div>
      {% if show_countdown %}
      <div class="countdown-wrap">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="var(--brand-secondary)" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        <div class="countdown">
          <span class="count-box" data-h>{{ section.settings.countdown_hours }}</span><span class="count-sep">:</span>
          <span class="count-box" data-m>{{ section.settings.countdown_minutes }}</span><span class="count-sep">:</span>
          <span class="count-box" data-s>{{ section.settings.countdown_seconds }}</span>
        </div>
      </div>
      {% endif %}
    </div>
    <div class="pc-container{% if layout == 'scroll' %} pc-has-scroll{% endif %}{% if center %} mt-8{% endif %}">
      {%- if layout == 'scroll' -%}<button class="pc-arrow pc-prev" type="button" aria-label="Previous" data-pc-prev><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg></button>{%- endif -%}
      <div class="{% if layout == 'scroll' %}pc-scroll{% else %}{{ grid_class }}{% endif %}" data-pc-track>
      {%- if use_dynamic -%}
        {%- comment -%} ===== MODE A: whole collection — auto product list (skips the product being viewed) ===== {%- endcomment -%}
        {%- liquid
          assign current_pid = 0
          if product != blank
            assign current_pid = product.id
          endif
          assign pc_shown = 0
        -%}
        {%- for item in col.products -%}
          {%- if item.id == current_pid -%}{%- continue -%}{%- endif -%}
          {%- if pc_shown >= section.settings.products_to_show -%}{%- break -%}{%- endif -%}
          {%- render 'product-card', product: item -%}
          {%- assign pc_shown = pc_shown | plus: 1 -%}
        {%- endfor -%}
      {%- else -%}
        {%- comment -%} ===== MODE B: per-block — hand-picked real product OR demo fallback ===== {%- endcomment -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'product' -%}
            {%- if block.settings.product != blank -%}
              {%- comment -%} merchant clicked "Add product" and picked a real one {%- endcomment -%}
              <div {{ block.shopify_attributes }}>
                {%- render 'product-card', product: block.settings.product, fallback_image: block.settings.image_default -%}
              </div>
            {%- else -%}
              {%- comment -%} demo/manual card so the section looks complete with no products {%- endcomment -%}
              {%- assign link = block.settings.link | default: '/collections/all' -%}
              <div class="product-card" {{ block.shopify_attributes }}>
                <div class="product-img-wrap">
                  {%- assign fallback_img = block.settings.image_default | default: 'prod-bulb.png' -%}
                  <a href="{{ link }}"><img src="{%- if block.settings.image != blank -%}{{ block.settings.image | image_url: width: 800 }}{%- else -%}{{ fallback_img | asset_url }}{%- endif -%}" alt="{{ block.settings.title | escape }}" width="800" height="800" loading="lazy" style="width:100%;height:100%;object-fit:cover;"></a>
                  {%- if block.settings.badge != blank -%}<span class="product-badge {{ block.settings.badge_style }}">{{ block.settings.badge }}</span>{%- endif -%}
                  <button class="btn-wishlist" type="button" aria-label="Add to wishlist"><span class="material-symbols-outlined">favorite</span></button>
                </div>
                <div class="product-body">
                  {% if block.settings.type != blank %}<p class="product-type">{{ block.settings.type }}</p>{% endif %}
                  <h3 class="product-title"><a href="{{ link }}">{{ block.settings.title }}</a></h3>
                  <div class="product-stars">{% render 'rating-stars', rating: block.settings.rating %}{% if block.settings.reviews != blank and block.settings.reviews != '0' %}<span class="review-count">({{ block.settings.reviews }})</span>{% endif %}</div>
                  <div class="product-price">{% if block.settings.old_price != blank %}<span class="old-price">QAR {{ block.settings.old_price }}</span>{% endif %}<span class="new-price">QAR {{ block.settings.price }}</span></div>
                  <button class="btn-cart" type="button"><span class="material-symbols-outlined" style="font-size:1.1rem;">shopping_cart</span> Add to Cart</button>
                </div>
              </div>
            {%- endif -%}
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
      </div>
      {%- if layout == 'scroll' -%}<button class="pc-arrow pc-next" type="button" aria-label="Next" data-pc-next><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg></button>{%- endif -%}
    </div>
  </div>
</section>

<script>
  (function () {
    var root = document.getElementById('PC--{{ section.id }}');
    if (!root) return;
    var track = root.querySelector('[data-pc-track]');
    var prev = root.querySelector('[data-pc-prev]');
    var next = root.querySelector('[data-pc-next]');
    if (!track || !prev || !next) return;
    function step() { var c = track.querySelector('.product-card'); return (c ? c.getBoundingClientRect().width + 24 : 280) * 2; }
    prev.addEventListener('click', function () { track.scrollBy({ left: -step(), behavior: 'smooth' }); });
    next.addEventListener('click', function () { track.scrollBy({ left: step(), behavior: 'smooth' }); });
  })();
</script>

{% if show_countdown %}
<script>
  (function () {
    var root = document.getElementById('PC--{{ section.id }}');
    if (!root) return;
    var h = root.querySelector('[data-h]');
    var m = root.querySelector('[data-m]');
    var s = root.querySelector('[data-s]');
    if (!h || !m || !s) return;
    var pad = function (n) { return n < 10 ? '0' + n : '' + n; };
    var total = (parseInt(h.textContent, 10) || 0) * 3600 + (parseInt(m.textContent, 10) || 0) * 60 + (parseInt(s.textContent, 10) || 0);
    var render = function () {
      var hh = Math.floor(total / 3600);
      var mm = Math.floor((total % 3600) / 60);
      var ss = total % 60;
      h.textContent = pad(hh);
      m.textContent = pad(mm);
      s.textContent = pad(ss);
    };
    render();
    var timer = setInterval(function () {
      if (total <= 0) { clearInterval(timer); return; }
      total -= 1;
      render();
    }, 1000);
  })();
</script>
{% endif %}
{%- endunless -%}

