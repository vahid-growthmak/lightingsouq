{%- comment -%} Product reviews section — v2 (resync) {%- endcomment -%}
{%- liquid
  assign real_rating = product.metafields.reviews.rating.value
  assign real_count = product.metafields.reviews.rating_count.value
  assign avg = real_rating | default: section.settings.avg_rating
  assign total = real_count | default: section.settings.review_total
  assign show = false
  if real_rating != blank or section.blocks.size > 0
    assign show = true
  endif
  comment Prefer the dedicated reviews page for "View more"; fall back to Google. endcomment
  assign more_href = section.settings.more_reviews_link
  assign more_external = false
  if more_href == blank
    assign more_href = section.settings.google_link
    assign more_external = true
  endif
-%}
{%- if show -%}
<section class="pdp-section" id="reviews">
  <h2 class="pdp-section-title">{{ section.settings.heading }}</h2>
  <p class="pdp-section-sub">{{ section.settings.subtitle }}</p>
  {%- if section.settings.google_show -%}
    <div class="pdp-google-reviews">
      {%- render 'google-reviews', rating: section.settings.google_rating, count: section.settings.google_count, link: section.settings.google_link -%}
      {%- if section.settings.google_link != blank -%}
        <a class="btn-outline" href="{{ section.settings.google_link }}" target="_blank" rel="noopener nofollow">Read all reviews on Google</a>
      {%- endif -%}
    </div>
  {%- endif -%}
  <div class="reviews-top">
    <div class="reviews-score">
      <div class="big">{{ avg }}</div>
      <div class="stars">{% render 'rating-stars', rating: avg %}</div>
      <div class="count">Based on {{ total }} reviews</div>
    </div>
    <div class="rating-bars">
      <div class="rating-bar-row"><span class="lbl">5 ★</span><div class="rating-bar-track"><div class="rating-bar-fill" style="width:{{ section.settings.pct_5 }}%"></div></div><span>{{ section.settings.pct_5 }}%</span></div>
      <div class="rating-bar-row"><span class="lbl">4 ★</span><div class="rating-bar-track"><div class="rating-bar-fill" style="width:{{ section.settings.pct_4 }}%"></div></div><span>{{ section.settings.pct_4 }}%</span></div>
      <div class="rating-bar-row"><span class="lbl">3 ★</span><div class="rating-bar-track"><div class="rating-bar-fill" style="width:{{ section.settings.pct_3 }}%"></div></div><span>{{ section.settings.pct_3 }}%</span></div>
      <div class="rating-bar-row"><span class="lbl">2 ★</span><div class="rating-bar-track"><div class="rating-bar-fill" style="width:{{ section.settings.pct_2 }}%"></div></div><span>{{ section.settings.pct_2 }}%</span></div>
      <div class="rating-bar-row"><span class="lbl">1 ★</span><div class="rating-bar-track"><div class="rating-bar-fill" style="width:{{ section.settings.pct_1 }}%"></div></div><span>{{ section.settings.pct_1 }}%</span></div>
    </div>
  </div>
  <div class="review-list-pdp">
    {% for block in section.blocks %}
    <div class="review-item{% if more_href == blank and forloop.index > section.settings.initial_count %} review-hidden{% endif %}" {{ block.shopify_attributes }}>
      <div class="review-item-head"><span class="review-item-author">{{ block.settings.name }} <span class="review-verified"><span class="material-symbols-outlined">check</span> Verified</span></span></div>
      <div class="stars">{% render 'rating-stars', rating: block.settings.rating %}</div>
      <p>{{ block.settings.text }}</p>
      <p class="rdate">{{ block.settings.date }}</p>
    </div>
    {% endfor %}
  </div>
  <div class="reviews-actions">
    {%- if more_href != blank -%}
      <a class="btn-view-more" href="{{ more_href }}"{% if more_external %} target="_blank" rel="noopener nofollow"{% endif %}><span class="material-symbols-outlined">reviews</span> {{ section.settings.view_more_label }}</a>
      {%- if section.settings.google_link != blank -%}
        <a class="btn-outline" href="{{ section.settings.google_link }}" target="_blank" rel="noopener nofollow">{{ section.settings.write_label }}</a>
      {%- endif -%}
    {%- else -%}
      <button class="btn-view-more" type="button" data-more><span class="material-symbols-outlined">expand_more</span> {{ section.settings.view_more_label }}</button>
      <button class="btn-outline" type="button">{{ section.settings.write_label }}</button>
    {%- endif -%}
  </div>
</section>

<script>
  (function () {
    var section = document.getElementById('reviews');
    if (!section) return;
    var btn = section.querySelector('[data-more]');
    if (!btn) return;
    var hidden = section.querySelectorAll('.review-hidden');
    if (!hidden.length) { btn.style.display = 'none'; return; }
    btn.addEventListener('click', function () {
      section.querySelectorAll('.review-hidden').forEach(function (el) { el.classList.remove('review-hidden'); });
      btn.style.display = 'none';
    });
  })();
</script>
{%- endif -%}

{% schema %}
{
  "name": "Product Reviews",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Customer Reviews"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Verified purchases from shoppers in Qatar."
    },
    {
      "type": "range",
      "id": "avg_rating",
      "label": "Average rating",
      "min": 0,
      "max": 5,
      "step": 0.1,
      "default": 4.8
    },
    {
      "type": "text",
      "id": "review_total",
      "label": "Total reviews",
      "default": "124"
    },
    { "type": "url", "id": "more_reviews_link", "label": "\"View more reviews\" page (e.g. Reviews page)" },
    { "type": "header", "content": "Google reviews" },
    { "type": "checkbox", "id": "google_show", "label": "Show Google reviews badge", "default": true },
    { "type": "text", "id": "google_rating", "label": "Google rating", "default": "4.9" },
    { "type": "text", "id": "google_count", "label": "Google review count", "default": "84" },
    { "type": "url", "id": "google_link", "label": "Google reviews link" },
    {
      "type": "range",
