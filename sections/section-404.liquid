{%- comment -%}
  404 — page not found. Centered message, search form, popular links as blocks.
{%- endcomment -%}
{%- liquid
  assign s = section.settings
-%}
<section class="section bg-white" id="Sec--{{ section.id }}" aria-labelledby="err-heading">
  <div class="container text-center">
    <p class="lsq-404-code">{{ s.error_code }}</p>
    <h1 class="section-title" id="err-heading">{{ s.heading }}</h1>
    {%- if s.subtext != blank -%}<p class="section-sub lsq-404-sub">{{ s.subtext }}</p>{%- endif -%}

    <form action="{{ routes.search_url }}" method="get" role="search" class="lsq-404-form">
      <input type="search" name="q" placeholder="{{ s.placeholder }}" aria-label="{{ s.placeholder }}" class="lsq-404-input">
      <button type="submit" class="btn-primary">{{ s.button_label }}</button>
    </form>

    {%- if section.blocks.size > 0 -%}
      <div class="lsq-404-links">
        <p class="lsq-404-links-title">{{ s.links_title }}</p>
        <ul>
          {%- for block in section.blocks -%}
            <li {{ block.shopify_attributes }}><a href="{{ block.settings.url }}">{{ block.settings.label }}</a></li>
          {%- endfor -%}
        </ul>
      </div>
    {%- endif -%}
  </div>
</section>

{% style %}
  #Sec--{{ section.id }} .lsq-404-code { font-size:3.5rem; font-weight:800; color:var(--brand-primary); line-height:1; }
  #Sec--{{ section.id }} .lsq-404-sub { max-width:520px; margin:0.75rem auto 1.5rem; }
  #Sec--{{ section.id }} .lsq-404-form { display:flex; gap:0.5rem; max-width:480px; margin:0 auto 2rem; }
  #Sec--{{ section.id }} .lsq-404-input {
    flex:1; padding:0.75rem 1rem; border:1px solid var(--gray-200,#e5e7eb); border-radius:var(--radius,8px); font-size:1rem;
  }
  #Sec--{{ section.id }} .lsq-404-input:focus { outline:2px solid var(--brand-primary); outline-offset:1px; }
  #Sec--{{ section.id }} .lsq-404-links-title { font-weight:700; margin-bottom:0.5rem; }
  #Sec--{{ section.id }} .lsq-404-links ul { list-style:none; display:flex; flex-wrap:wrap; gap:0.5rem 1.25rem; justify-content:center; padding:0; }
  #Sec--{{ section.id }} .lsq-404-links a { color:var(--brand-link,#268290); font-weight:600; }
{% endstyle %}

{% schema %}
{
  "name": "404 Not Found",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "error_code", "label": "Error code", "default": "404" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "This page went dark" },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "The page you were looking for could not be found. Try a search or one of the links below." },
    { "type": "text", "id": "placeholder", "label": "Search placeholder", "default": "Search the store" },
    { "type": "text", "id": "button_label", "label": "Search button label", "default": "Search" },
    { "type": "text", "id": "links_title", "label": "Popular links title", "default": "Popular links" }
  ],
  "blocks": [
    {
      "type": "link",
      "name": "Link",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Shop all" },
        { "type": "url", "id": "url", "label": "URL", "default": "/collections/all" }
      ]
    }
  ],
  "presets": [
    {
      "name": "404 Not Found",
      "blocks": [
        { "type": "link", "settings": { "label": "Smart Lights", "url": "/collections/all" } },
        { "type": "link", "settings": { "label": "LED Bulbs", "url": "/collections/all" } },
        { "type": "link", "settings": { "label": "Deals", "url": "/collections/all" } },
        { "type": "link", "settings": { "label": "Contact", "url": "/collections/all" } }
      ]
    }
  ]
}
{% endschema %}
