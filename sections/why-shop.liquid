{%- liquid
  assign bg = section.settings.bg
-%}
{%- style -%}
  #WS--{{ section.id }} .why-icon-wrap .material-symbols-outlined { font-size: 1.9rem; color: var(--brand-primary); font-variation-settings: 'FILL' 1; }
{%- endstyle -%}
<section class="section {{ bg }}" id="WS--{{ section.id }}">
  <div class="container">
    <h2 class="section-title text-center">{{ section.settings.heading }}</h2>
    <div class="grid-4 mt-8">
      {%- for block in section.blocks -%}
        {%- if block.type == 'benefit' -%}
          <div class="why-card" {{ block.shopify_attributes }}>
            <div class="why-icon-wrap"><span class="material-symbols-outlined">{{ block.settings.icon | default: 'star' }}</span></div>
            <h3 class="why-title">{{ block.settings.title }}</h3>
            <p class="why-desc">{{ block.settings.description }}</p>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Why Shop",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why Shop from Lighting Souq"
    },
    {
      "type": "select",
      "id": "bg",
      "label": "Background",
      "options": [
        { "value": "bg-white", "label": "White" },
        { "value": "bg-gray", "label": "Gray" }
      ],
      "default": "bg-gray"
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        { "type": "text", "id": "icon", "label": "Icon (Material Symbol name)", "default": "lightbulb" },
        { "type": "text", "id": "title", "label": "Title", "default": "Benefit" },
        { "type": "textarea", "id": "description", "label": "Description" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Why Shop",
      "blocks": [
        { "type": "benefit", "settings": { "icon": "lightbulb", "title": "Wide Lighting Collection", "description": "From smart bulbs to solar lights, find everything you need" } },
        { "type": "benefit", "settings": { "icon": "local_shipping", "title": "Fast Delivery Across Qatar", "description": "Free delivery on orders above QAR 150" } },
        { "type": "benefit", "settings": { "icon": "chat", "title": "Easy WhatsApp Ordering", "description": "Chat with us anytime for quick support" } },
        { "type": "benefit", "settings": { "icon": "verified", "title": "Trusted Local Store", "description": "Theqa certified with 4.9★ Google rating" } }
      ]
    }
  ]
}
{% endschema %}
