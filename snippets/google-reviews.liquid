{%- comment -%}
  Google reviews badge — aggregate rating + count + link to Google.
  Params: rating, count, link, variant ('light' default | 'onblue' | 'inline')
{%- endcomment -%}
{%- liquid
  assign r = rating | default: 4.9
  assign n = count | default: 84
  assign href = link
  if href == blank
    assign href = '#'
  endif
  assign v = variant | default: 'light'
-%}
<a class="gr-badge gr-badge--{{ v }}" href="{{ href }}" target="_blank" rel="noopener nofollow" aria-label="{{ r }} star Google rating from {{ n }} reviews">
  <svg class="gr-g" viewBox="0 0 24 24" width="22" height="22" aria-hidden="true" focusable="false">
    <path fill="#4285F4" d="M23.5 12.27c0-.79-.07-1.54-.2-2.27H12v4.51h6.47a5.53 5.53 0 0 1-2.4 3.58v2.98h3.88c2.27-2.09 3.55-5.17 3.55-8.8z"/>
    <path fill="#34A853" d="M12 24c3.24 0 5.96-1.08 7.95-2.91l-3.88-3.01c-1.08.72-2.45 1.16-4.07 1.16-3.13 0-5.78-2.11-6.73-4.96H1.29v3.11A12 12 0 0 0 12 24z"/>
    <path fill="#FBBC05" d="M5.27 14.28a7.19 7.19 0 0 1 0-4.56V6.61H1.29a12 12 0 0 0 0 10.78l3.98-3.11z"/>
    <path fill="#EA4335" d="M12 4.75c1.77 0 3.35.61 4.6 1.8l3.44-3.44A11.98 11.98 0 0 0 12 0 12 12 0 0 0 1.29 6.61l3.98 3.11C6.22 6.86 8.87 4.75 12 4.75z"/>
  </svg>
  <span class="gr-body">
    <span class="gr-top"><strong class="gr-score">{{ r }}</strong><span class="gr-stars">{%- render 'rating-stars', rating: r -%}</span></span>
    <span class="gr-sub">{{ n }} {{ settings.google_reviews_label | default: 'Google reviews' | escape }}</span>
  </span>
</a>
