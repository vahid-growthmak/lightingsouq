{%- comment -%}
  Renders a real payment icon from a label (Visa, MC/Mastercard, Apple Pay, COD,
  Google Pay, mada, Tabby, Amex, PayPal). Card brands use the official brand SVG
  assets; regional/alt methods fall back to clean inline marks.
  Param: label
{%- endcomment -%}
{%- assign k = label | downcase | strip | replace: '.', '' -%}
{%- case k -%}
  {%- when 'visa' -%}
    <img class="pay-chip pay-chip--card" src="{{ 'pay-visa.svg' | asset_url }}" alt="Visa" width="62" height="40" loading="lazy">
  {%- when 'mc', 'mastercard', 'master card' -%}
    <img class="pay-chip pay-chip--card" src="{{ 'pay-mastercard.svg' | asset_url }}" alt="Mastercard" width="62" height="40" loading="lazy">
  {%- when 'amex', 'american express' -%}
    <img class="pay-chip pay-chip--card" src="{{ 'pay-amex.svg' | asset_url }}" alt="American Express" width="62" height="40" loading="lazy">
  {%- when 'paypal' -%}
    <img class="pay-chip pay-chip--card" src="{{ 'pay-paypal.svg' | asset_url }}" alt="PayPal" width="62" height="40" loading="lazy">
  {%- when 'apple pay', 'applepay' -%}
    <span class="pay-chip pay-chip--wm"><img src="{{ 'pay-applepay.svg' | asset_url }}" alt="Apple Pay" loading="lazy"></span>
  {%- when 'google pay', 'gpay', 'googlepay' -%}
    <span class="pay-chip pay-chip--wm"><img src="{{ 'pay-googlepay.svg' | asset_url }}" alt="Google Pay" loading="lazy"></span>
  {%- when 'mada' -%}
    <span class="pay-chip pay-chip--wm"><svg viewBox="0 0 48 20" role="img" aria-label="mada"><text x="24" y="15" text-anchor="middle" font-family="Arial,Helvetica,sans-serif" font-size="13" font-weight="800" fill="#84368b">mada</text></svg></span>
  {%- when 'tabby' -%}
    <span class="pay-chip pay-chip--tabby"><svg viewBox="0 0 48 20" role="img" aria-label="Tabby"><text x="24" y="15" text-anchor="middle" font-family="Arial,Helvetica,sans-serif" font-size="12" font-weight="800" fill="#0a1b2a">tabby</text></svg></span>
  {%- when 'cod', 'cash on delivery' -%}
    <span class="pay-chip pay-chip--wm pay-chip--cod">
      <svg viewBox="0 0 44 20" role="img" aria-label="Cash on Delivery">
        <rect x="4" y="6" width="15" height="9.5" rx="1.6" fill="none" stroke="#059669" stroke-width="1.4"/>
        <circle cx="11.5" cy="10.75" r="2.4" fill="#059669"/>
        <text x="31" y="14" text-anchor="middle" font-family="Arial,Helvetica,sans-serif" font-size="9.5" font-weight="800" fill="#059669">COD</text>
      </svg>
    </span>
  {%- else -%}
    <span class="pay-badge">{{ label }}</span>
{%- endcase -%}
