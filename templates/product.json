        "b1": {
          "type": "faq",
          "settings": {
            "question": "How fast is delivery in Qatar?",
            "answer": "<p>Order before 4 PM for <strong>same-day delivery in Doha</strong>. Elsewhere in Qatar it's 1–2 days, and we also ship across the GCC. Free delivery on orders over QAR 150.</p>"
